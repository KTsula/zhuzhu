---
import { menuBundles } from '../content/copy';
---
<section class="zz-bundles" id="baskets">
  <div class="shell">
    <header class="head">
      <span class="eyebrow label">
        <span class="lng-en">{menuBundles.en.eyebrow}</span>
        <span class="lng-ka">{menuBundles.ka.eyebrow}</span>
      </span>
      <div class="head-grid">
        <h2 class="display title">
          <span class="lng-en">{menuBundles.en.head}</span>
          <span class="lng-ka">{menuBundles.ka.head}</span>
        </h2>
        <p class="sub">
          <span class="lng-en">{menuBundles.en.sub}</span>
          <span class="lng-ka">{menuBundles.ka.sub}</span>
        </p>
      </div>
    </header>

    <div class="cards">
      {menuBundles.tiers.map((tier) => (
        <article class:list={['bundle-card', tier.featured && 'featured']}>
          {tier.featured && (
            <span class="ribbon">
              <span class="lng-en">{tier.kicker.en}</span>
              <span class="lng-ka">{tier.kicker.ka}</span>
            </span>
          )}

          <div class="card-top">
            <span class="bundle-id">№ {tier.id}</span>
            {!tier.featured && (
              <span class="kicker">
                <span class="lng-en">{tier.kicker.en}</span>
                <span class="lng-ka">{tier.kicker.ka}</span>
              </span>
            )}
          </div>

          <h3 class="display name">
            <span class="lng-en">{tier.name.en}</span>
            <span class="lng-ka ka">{tier.name.ka}</span>
          </h3>

          <div class="stats">
            <div class="stat">
              <span class="lng-en">{tier.guests.en}</span>
              <span class="lng-ka">{tier.guests.ka}</span>
            </div>
            <div class="stat">
              <span class="lng-en">{tier.cubes.en}</span>
              <span class="lng-ka">{tier.cubes.ka}</span>
            </div>
          </div>

          <p class="body">
            <span class="lng-en">{tier.body.en}</span>
            <span class="lng-ka">{tier.body.ka}</span>
          </p>

          <div class="price-block">
            <span class="price-label">
              <span class="lng-en">{menuBundles.en.priceLabel}</span>
              <span class="lng-ka">{menuBundles.ka.priceLabel}</span>
            </span>
            <span class="price">{tier.price}</span>
          </div>

          <div class="mix">
            <span class="mix-label">
              <span class="lng-en">{menuBundles.en.mixLabel}</span>
              <span class="lng-ka">{menuBundles.ka.mixLabel}</span>
            </span>
            <ul>
              {tier.mix.map((item) => (
                <li>
                  <span class="count">{item.count}</span>
                  <span>
                    <span class="lng-en">{item.label.en}</span>
                    <span class="lng-ka">{item.label.ka}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <p class="note">
            <span class="lng-en">{tier.note.en}</span>
            <span class="lng-ka">{tier.note.ka}</span>
          </p>
        </article>
      ))}
    </div>

    <footer class="bundle-foot">
      <p>
        <span class="lng-en">{menuBundles.en.foot}</span>
        <span class="lng-ka">{menuBundles.ka.foot}</span>
      </p>
      <a class="cta" href="/order#book">
        <span class="lng-en">{menuBundles.en.cta}</span>
        <span class="lng-ka">{menuBundles.ka.cta}</span>
      </a>
    </footer>
  </div>
</section>

<style>
  .zz-bundles {
    position: relative;
    isolation: isolate;
    padding: 116px 24px 104px;
    background:
      radial-gradient(720px 360px at 18% 8%, rgba(183, 58, 90, 0.18), transparent 70%),
      radial-gradient(680px 360px at 88% 20%, rgba(198, 152, 89, 0.16), transparent 72%),
      linear-gradient(180deg, var(--night) 0%, var(--graphite) 48%, var(--night) 100%);
    overflow: hidden;
  }
  .zz-bundles::before {
    content: "";
    position: absolute;
    inset: 36px 24px;
    border: 1px solid rgba(198, 152, 89, 0.12);
    pointer-events: none;
    z-index: -1;
  }
  .shell {
    max-width: 1240px;
    margin: 0 auto;
  }
  .head {
    margin-bottom: 56px;
  }
  .eyebrow {
    display: block;
    color: var(--gold);
    margin-bottom: 24px;
  }
  .head-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.72fr);
    gap: 64px;
    align-items: end;
  }
  .title {
    font-size: var(--t-display);
    margin: 0;
    max-width: 10ch;
  }
  .sub {
    margin: 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    line-height: 1.7;
    color: var(--bone-warm);
  }
  html[data-lang="ka"] .sub { font-family: var(--ka); font-weight: 400; }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: rgba(198, 152, 89, 0.2);
    border: 1px solid rgba(198, 152, 89, 0.2);
  }
  .bundle-card {
    position: relative;
    min-height: 680px;
    padding: 34px 30px 30px;
    background:
      linear-gradient(180deg, rgba(237, 225, 196, 0.035), rgba(237, 225, 196, 0)),
      var(--night);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .bundle-card::after {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    right: -86px;
    top: 132px;
    background: radial-gradient(circle, rgba(198, 152, 89, 0.18), transparent 68%);
    pointer-events: none;
  }
  .bundle-card.featured {
    background:
      radial-gradient(360px 280px at 78% 10%, rgba(227, 183, 109, 0.18), transparent 72%),
      linear-gradient(180deg, rgba(198, 152, 89, 0.13), rgba(237, 225, 196, 0.025)),
      var(--graphite);
  }
  .ribbon {
    position: absolute;
    top: 0;
    right: 0;
    padding: 10px 16px;
    background: var(--gold);
    color: var(--night);
    font-family: var(--body);
    font-weight: 700;
    font-size: var(--t-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  html[data-lang="ka"] .ribbon {
    font-family: var(--ka);
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: var(--t-sm);
  }
  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 34px;
    color: var(--ash);
  }
  .bundle-id {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }
  .kicker {
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  html[data-lang="ka"] .kicker {
    font-family: var(--ka);
    font-style: italic;
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: var(--t-sm);
  }
  .name {
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
  }
  .name .ka {
    font-size: clamp(1.8rem, 3vw, 2.55rem);
  }
  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }
  .stat {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(198, 152, 89, 0.28);
    color: var(--bone-warm);
    padding: 7px 10px;
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  html[data-lang="ka"] .stat {
    font-family: var(--ka);
    font-style: italic;
    letter-spacing: 0.03em;
    text-transform: none;
    font-size: var(--t-sm);
  }
  .body {
    margin: 28px 0 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    line-height: 1.62;
    color: var(--bone-warm);
    max-width: 34ch;
  }
  html[data-lang="ka"] .body { font-family: var(--ka); font-weight: 400; }

  .price-block {
    margin-top: 34px;
    padding-top: 28px;
    border-top: 1px solid rgba(198, 152, 89, 0.18);
  }
  .price-label,
  .mix-label {
    display: block;
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
  }
  html[data-lang="ka"] .price-label,
  html[data-lang="ka"] .mix-label {
    font-family: var(--ka);
    font-style: italic;
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: var(--t-sm);
  }
  .price {
    display: block;
    margin-top: 6px;
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.4rem, 4vw, 3.65rem);
    line-height: 1;
    color: var(--gold-bright);
  }

  .mix {
    margin-top: 36px;
  }
  .mix ul {
    margin-top: 18px;
    display: grid;
    gap: 13px;
  }
  .mix li {
    display: grid;
    grid-template-columns: 44px 1fr;
    align-items: baseline;
    gap: 14px;
    color: var(--bone);
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
  }
  html[data-lang="ka"] .mix li { font-family: var(--ka); font-size: var(--t-base); }
  .count {
    font-family: var(--display);
    font-style: italic;
    font-size: var(--t-lg);
    color: var(--gold);
    line-height: 1;
  }
  .note {
    margin: auto 0 0;
    padding-top: 34px;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-sm);
    line-height: 1.5;
    color: var(--ash);
    max-width: 34ch;
  }
  html[data-lang="ka"] .note { font-family: var(--ka); font-weight: 400; font-size: var(--t-base); }

  .bundle-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding-top: 36px;
  }
  .bundle-foot p {
    margin: 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
  }
  html[data-lang="ka"] .bundle-foot p { font-family: var(--ka); font-weight: 400; }
  .bundle-foot .cta {
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .head-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .title {
      max-width: 12ch;
    }
    .cards {
      grid-template-columns: 1fr;
    }
    .bundle-card {
      min-height: 0;
    }
    .note {
      margin-top: 44px;
    }
  }
  @media (max-width: 720px) {
    .zz-bundles {
      padding: 76px 22px 76px;
    }
    .zz-bundles::before {
      inset: 20px 12px;
    }
    .head {
      margin-bottom: 40px;
    }
    .title {
      font-size: var(--t-3xl);
    }
    .sub,
    .body,
    .bundle-foot p {
      font-size: var(--t-base);
    }
    .bundle-card {
      padding: 30px 24px 26px;
    }
    .bundle-foot {
      align-items: stretch;
      flex-direction: column;
    }
    .bundle-foot .cta {
      width: 100%;
    }
  }
</style>
