---
interface Props {
  /** Delay in ms before this element animates in once intersected. */
  delay?: number;
  as?: keyof HTMLElementTagNameMixin extends never ? string : string;
  class?: string;
}
const { delay = 0, as = 'div', class: className = '' } = Astro.props;
const Tag = as as any;
---
<Tag class={`reveal ${className}`} style={delay ? `transition-delay: ${delay}ms` : undefined}>
  <slot />
</Tag>
