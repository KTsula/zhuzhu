---
import Base from '../layouts/Base.astro';
import { boxPage, pageMeta } from '../content/copy';
---
<Base current="box"
      title={pageMeta.box.en.title}
      description={pageMeta.box.en.desc}>
  <section class="zz-box-hero">
    <span class="eyebrow label">
      <span class="lng-en">{boxPage.en.eyebrow}</span>
      <span class="lng-ka">{boxPage.ka.eyebrow}</span>
    </span>

    <h1 class="display head">
      <span class="lng-en">{boxPage.en.head}</span>
      <span class="lng-ka">{boxPage.ka.head}</span>
    </h1>

    <p class="sub">
      <span class="lng-en">{boxPage.en.sub}</span>
      <span class="lng-ka">{boxPage.ka.sub}</span>
    </p>

    <div class="price-block">
      <div class="price-row">
        <span class="price"><span class="lng-en">{boxPage.en.price}</span><span class="lng-ka">{boxPage.ka.price}</span></span>
        <span class="cadence"><span class="lng-en">{boxPage.en.cadence}</span><span class="lng-ka">{boxPage.ka.cadence}</span></span>
      </div>
      <div class="price-note">
        <span class="lng-en">{boxPage.en.priceNote}</span>
        <span class="lng-ka">{boxPage.ka.priceNote}</span>
      </div>
    </div>

    <button class="cta subscribe-btn" id="zz-subscribe">
      <span class="lng-en">{boxPage.en.cta}</span>
      <span class="lng-ka">{boxPage.ka.cta}</span>
    </button>
  </section>

  <section class="zz-box-steps">
    <h2 class="display steps-head">
      <span class="lng-en">{boxPage.en.stepsHead}</span>
      <span class="lng-ka">{boxPage.ka.stepsHead}</span>
    </h2>

    <ol class="steps">
      {boxPage.en.steps.map((s, i) => {
        const ka = boxPage.ka.steps[i];
        return (
          <li class="step">
            <span class="n">{s.n}</span>
            <div class="body">
              <h3 class="name">
                <span class="lng-en">{s.name}</span>
                <span class="lng-ka">{ka.name}</span>
              </h3>
              <p class="d">
                <span class="lng-en">{s.d}</span>
                <span class="lng-ka">{ka.d}</span>
              </p>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="zz-box-final">
    <h2 class="display final-head">
      <span class="lng-en">{boxPage.en.finalHead}</span>
      <span class="lng-ka">{boxPage.ka.finalHead}</span>
    </h2>
    <button class="cta subscribe-btn" id="zz-subscribe-2">
      <span class="lng-en">{boxPage.en.finalCta}</span>
      <span class="lng-ka">{boxPage.ka.finalCta}</span>
    </button>
  </section>
</Base>

<script is:inline>
  // TODO Paddle Billing: load https://cdn.paddle.com/paddle/v2/paddle.js in Base.astro,
  // run Paddle.Initialize({ token: 'YOUR_CLIENT_TOKEN' }), then replace the alert below
  // with: Paddle.Checkout.open({ items: [{ priceId: 'pri_XXX', quantity: 1 }] });
  (function () {
    var btns = document.querySelectorAll('#zz-subscribe, #zz-subscribe-2');
    btns.forEach(function (b) {
      b.addEventListener('click', function () {
        var lang = document.documentElement.getAttribute('data-lang') === 'ka' ? 'ka' : 'en';
        alert(lang === 'ka'
          ? 'გადახდა მალე ხელმისაწვდომი იქნება. ამ დროისთვის მოგვწერეთ hello@zhuzhu.ge.'
          : 'Checkout coming soon. Write to hello@zhuzhu.ge in the meantime to reserve your spot.');
      });
    });
  })();
</script>

<style>
  .zz-box-hero {
    padding: 140px 24px 100px;
    background: var(--night);
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .zz-box-hero .eyebrow {
    display: block;
    color: var(--gold);
    margin-bottom: 28px;
  }
  .zz-box-hero .head {
    font-size: var(--t-display);
    margin: 0;
  }
  .zz-box-hero .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 42ch;
    margin: 36px auto 0;
  }
  html[data-lang="ka"] .zz-box-hero .sub { font-family: var(--ka); font-weight: 400; }

  .price-block {
    margin: 64px auto 0;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 56px;
    border-top: 1px solid rgba(198,152,89,0.3);
    border-bottom: 1px solid rgba(198,152,89,0.3);
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    color: var(--bone);
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
  }
  .price { font-size: var(--t-display); line-height: 1; }
  .cadence { font-size: var(--t-lg); color: var(--bone-warm); }
  html[data-lang="ka"] .price-row { font-family: var(--ka); font-weight: 400; }
  .price-note {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--ash);
    letter-spacing: 0.04em;
  }
  html[data-lang="ka"] .price-note { font-family: var(--ka); font-weight: 400; }

  .subscribe-btn {
    margin-top: 40px;
    padding: 20px 44px;
    font-size: var(--t-sm);
  }
  html[data-lang="ka"] .subscribe-btn { font-size: var(--t-base); }

  .zz-box-steps {
    padding: 110px 24px;
    background: var(--night);
    max-width: 920px;
    margin: 0 auto;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .steps-head {
    font-size: var(--t-2xl);
    margin: 0 0 56px;
    text-align: center;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1px;
    background: rgba(198,152,89,0.18);
  }
  .step {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 36px 0;
    background: var(--night);
  }
  .step .n {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-2xl);
    color: var(--gold);
    line-height: 1;
  }
  .step .name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-lg);
    color: var(--bone);
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  html[data-lang="ka"] .step .name {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 500;
  }
  .step .d {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    max-width: 58ch;
    margin: 0;
  }
  html[data-lang="ka"] .step .d { font-family: var(--ka); font-weight: 400; }

  .zz-box-final {
    padding: 140px 24px 160px;
    background: var(--night);
    text-align: center;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .final-head {
    font-size: var(--t-3xl);
    margin: 0 0 48px;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 720px) {
    .zz-box-hero { padding: 88px 22px 72px; }
    .zz-box-hero .eyebrow { margin-bottom: 20px; }
    .zz-box-hero .head { font-size: var(--t-3xl); }
    .zz-box-hero .sub { font-size: var(--t-base); margin-top: 28px; }
    .price-block {
      margin-top: 48px;
      padding: 24px 32px;
    }
    .price-row { gap: 6px; }
    .cadence { font-size: var(--t-base); }
    .subscribe-btn {
      margin-top: 32px;
      width: 100%;
      max-width: 320px;
      padding: 18px 28px;
    }
    .zz-box-steps { padding: 72px 22px; }
    .steps-head { font-size: var(--t-xl); margin-bottom: 40px; }
    .step { grid-template-columns: 56px 1fr; gap: 20px; padding: 28px 0; }
    .step .n { font-size: var(--t-xl); }
    .step .name { font-size: var(--t-base); margin-bottom: 8px; }
    .zz-box-final { padding: 88px 22px 104px; }
    .final-head { font-size: var(--t-2xl); margin-bottom: 36px; }
  }
</style>
