---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HookVeil from '../components/HookVeil.astro';
import { pageMeta } from '../content/copy';

interface Props {
  title?: string;
  description?: string;
  current?: 'menu' | 'order' | 'box' | 'about' | 'contact' | 'home';
  showHook?: boolean;
}
const {
  title = pageMeta.home.en.title,
  description = pageMeta.home.en.desc,
  current = 'home',
  showHook = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://zhuzhu.ge').toString();
---
<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0706" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Pinterest domain verification. Required to claim zhuzhu.ge on Pinterest. -->
    <meta name="p:domain_verify" content="504f3b81138f15fefa9d41a23bac0be4" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site ?? 'https://zhuzhu.ge').toString()} />
    <meta property="og:image:secure_url" content={new URL('/og.png', Astro.site ?? 'https://zhuzhu.ge').toString()} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ZhuZhu — cocktail desserts, hand-set in Tbilisi" />
    <meta property="og:site_name" content="ZhuZhu" />
    <meta property="og:locale" content="en_GE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site ?? 'https://zhuzhu.ge').toString()} />
    <meta name="twitter:image:alt" content="ZhuZhu — cocktail desserts, hand-set in Tbilisi" />

    <script is:inline>
      // Set <html data-lang> from localStorage as early as possible to avoid FOUC.
      (function () {
        try {
          var v = localStorage.getItem('zz-lang');
          if (v !== 'en' && v !== 'ka') {
            var b = (navigator.language || 'en').slice(0, 2).toLowerCase();
            v = b === 'ka' ? 'ka' : 'en';
          }
          document.documentElement.setAttribute('data-lang', v);
          document.documentElement.setAttribute('lang', v);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {showHook && <HookVeil />}
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import '../scripts/lang';

      const prm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prm) {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
