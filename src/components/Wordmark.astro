---
interface Props {
  size?: number;
  href?: string;
}
const { size = 22, href = '/' } = Astro.props;
---
<a class="zz-wordmark" href={href} aria-label="ZhuZhu, home">
  <span class="mark lng-en" style={`font-size:${size}px`}>ZhuZhu</span>
  <span class="mark ka lng-ka" style={`font-size:${Math.round(size * 0.95)}px`}>ჟუჟუ</span>
</a>

<style>
  .zz-wordmark {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    color: inherit;
  }
  .mark {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    color: var(--bone);
    letter-spacing: -0.005em;
  }
  .mark.ka {
    font-family: var(--ka);
    font-weight: 400;
  }
</style>
