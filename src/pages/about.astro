---
import Base from '../layouts/Base.astro';
import { aboutPage, founders, pageMeta } from '../content/copy';
---
<Base current="about"
      title={pageMeta.about.en.title}
      description={pageMeta.about.en.desc}>
  <section class="origin">
    <h1 class="display title">
      <span class="lng-en" set:html={aboutPage.en.head} />
      <span class="lng-ka" set:html={aboutPage.ka.head} />
    </h1>
    <div class="paras lng-en">{aboutPage.en.origin.map((p) => <p>{p}</p>)}</div>
    <div class="paras lng-ka">{aboutPage.ka.origin.map((p) => <p>{p}</p>)}</div>
  </section>

  <section class="founders-section">
    <div class="founders">
      {founders.map((f) => (
        <article class="founder">
          <div class="vignette">
            <div class="glow" style={`background: radial-gradient(60% 50% at 50% 55%, ${f.accent} 0%, rgba(10,7,6,0) 72%)`}></div>
          </div>
          <h3 class="name display">
            <span class="lng-en">{f.name.en}</span>
            <span class="lng-ka">{f.name.ka}</span>
          </h3>
          <div class="role">
            <span class="lng-en">{f.role.en}</span>
            <span class="lng-ka">{f.role.ka}</span>
          </div>
          <p class="bio">
            <span class="lng-en">{f.bio.en}</span>
            <span class="lng-ka">{f.bio.ka}</span>
          </p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .origin {
    padding: 140px 24px 110px;
    background: var(--night);
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .origin .title {
    font-size: var(--t-3xl);
    margin: 0;
    line-height: 1.15;
  }
  .paras { margin-top: 64px; text-align: left; }
  .paras p {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.7;
    margin: 0 0 24px;
    max-width: 60ch;
  }
  html[data-lang="ka"] .paras p { font-family: var(--ka); font-weight: 400; }

  .founders-section {
    padding: 100px 40px;
    background: var(--night);
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .founders {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 64px;
  }
  .founder { display: flex; flex-direction: column; gap: 18px; }
  .vignette {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--night);
    overflow: hidden;
    border-bottom: 1px solid rgba(198,152,89,0.18);
  }
  .vignette .glow { position: absolute; inset: 0; }
  .name {
    margin: 8px 0 0;
    font-size: var(--t-xl);
  }
  .role {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ash);
  }
  html[data-lang="ka"] .role {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .bio {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    margin: 0;
  }
  html[data-lang="ka"] .bio { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 1024px) {
    .founders { grid-template-columns: 1fr; gap: 56px; }
  }
  @media (max-width: 720px) {
    .origin { padding: 80px 22px 64px; }
    .paras { margin-top: 40px; }
    .founders-section { padding: 64px 22px; }
  }
</style>
