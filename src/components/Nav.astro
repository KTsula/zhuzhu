---
import LangSwitch from './LangSwitch.astro';
import Wordmark from './Wordmark.astro';
import { nav } from '../content/copy';

interface Props { current?: 'menu' | 'order' | 'box' | 'about' | 'contact' | 'home'; }
const { current = 'home' } = Astro.props;
---
<header class="zz-nav">
  <div class="brand"><Wordmark size={22} /></div>

  <nav class="links" aria-label="Primary">
    <a href="/menu" class:list={[current === 'menu' && 'active']}>
      <span class="lng-en">{nav.en.menu}</span><span class="lng-ka">{nav.ka.menu}</span>
    </a>
    <a href="/order" class:list={[current === 'order' && 'active']}>
      <span class="lng-en">{nav.en.order}</span><span class="lng-ka">{nav.ka.order}</span>
    </a>
    <a href="/box" class:list={[current === 'box' && 'active']}>
      <span class="lng-en">{nav.en.box}</span><span class="lng-ka">{nav.ka.box}</span>
    </a>
    <a href="/about" class:list={[current === 'about' && 'active']}>
      <span class="lng-en">{nav.en.about}</span><span class="lng-ka">{nav.ka.about}</span>
    </a>
    <a href="/contact" class:list={[current === 'contact' && 'active']}>
      <span class="lng-en">{nav.en.contact}</span><span class="lng-ka">{nav.ka.contact}</span>
    </a>
  </nav>

  <div class="right">
    <LangSwitch />
    <a class="reserve" href="/#book">
      <span class="lng-en">{nav.en.reserve}</span><span class="lng-ka">{nav.ka.reserve}</span>
    </a>
  </div>

  <div class="mobile-right">
    <a class="reserve mobile-reserve" href="/#book">
      <span class="lng-en">{nav.en.reserve}</span><span class="lng-ka">{nav.ka.reserve}</span>
    </a>
    <button class="menu-trigger" aria-label="Open menu" id="zz-menu-trigger">
      <span></span><span></span>
    </button>
  </div>
</header>

<aside class="mobile-drawer" id="zz-mobile-drawer" aria-hidden="true">
  <div class="drawer-inner">
    <button class="drawer-close" aria-label="Close menu" id="zz-menu-close">×</button>
    <nav class="drawer-links">
      <a href="/menu">
        <span class="lng-en">{nav.en.menu}</span><span class="lng-ka">{nav.ka.menu}</span>
      </a>
      <a href="/order">
        <span class="lng-en">{nav.en.order}</span><span class="lng-ka">{nav.ka.order}</span>
      </a>
      <a href="/box">
        <span class="lng-en">{nav.en.box}</span><span class="lng-ka">{nav.ka.box}</span>
      </a>
      <a href="/about">
        <span class="lng-en">{nav.en.about}</span><span class="lng-ka">{nav.ka.about}</span>
      </a>
      <a href="/contact">
        <span class="lng-en">{nav.en.contact}</span><span class="lng-ka">{nav.ka.contact}</span>
      </a>
      <a class="cta drawer-cta" href="/#book">
        <span class="lng-en">{nav.en.reserveTasting}</span><span class="lng-ka">{nav.ka.reserveTasting}</span>
      </a>
    </nav>
    <div class="drawer-lang"><LangSwitch size="lg" /></div>
  </div>
</aside>

<script>
  const trigger = document.getElementById('zz-menu-trigger');
  const drawer = document.getElementById('zz-mobile-drawer');
  const close = document.getElementById('zz-menu-close');
  function open()  { drawer?.setAttribute('aria-hidden', 'false'); document.body.classList.add('menu-open'); }
  function shut() { drawer?.setAttribute('aria-hidden', 'true');  document.body.classList.remove('menu-open'); }
  trigger?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
</script>

<style>
  .zz-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 22px 40px;
    background: rgba(10, 7, 6, 0.85);
    backdrop-filter: blur(12px);
    gap: 24px;
  }
  .brand { justify-self: start; }
  .links { display: flex; gap: 36px; justify-self: center; }
  .links a {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-sm);
    color: var(--bone-warm);
    transition: color 0.3s var(--ease-out-quart);
    padding: 4px 0;
  }
  html[data-lang="ka"] .links a { font-family: var(--ka); font-style: italic; font-weight: 400; font-size: var(--t-base); }
  .links a:hover, .links a.active { color: var(--gold-bright); }

  .right { display: flex; align-items: center; gap: 28px; justify-self: end; }
  .reserve {
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bone);
    border-bottom: 1px solid var(--gold);
    padding: 6px 0 8px;
    transition: color 0.3s var(--ease-out-quart), border-color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .reserve { font-family: var(--ka); font-style: italic; text-transform: none; letter-spacing: 0.04em; font-size: var(--t-sm); }
  .reserve:hover { color: var(--gold-bright); border-color: var(--gold-bright); }

  .mobile-right { display: none; align-items: center; gap: 18px; justify-self: end; }

  .menu-trigger {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 8px;
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
  }
  .menu-trigger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--bone);
  }

  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--night);
    transform: translateX(100%);
    transition: transform 0.5s var(--ease-out-quart);
    visibility: hidden;
  }
  .mobile-drawer[aria-hidden="false"] { transform: translateX(0); visibility: visible; }
  .drawer-inner {
    height: 100%;
    padding: 28px 28px 40px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .drawer-close {
    align-self: flex-end;
    background: transparent;
    border: 0;
    color: var(--bone);
    width: 44px;
    height: 44px;
    font-size: 32px;
    cursor: pointer;
    font-family: var(--display);
    font-weight: 200;
    line-height: 1;
  }
  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 20px;
  }
  .drawer-links a {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-2xl);
    color: var(--bone);
    border-bottom: 1px solid rgba(198,152,89,0.18);
    padding: 22px 0;
  }
  html[data-lang="ka"] .drawer-links a { font-family: var(--ka); }
  .drawer-cta {
    margin-top: 24px;
    font-family: var(--body) !important;
    font-style: normal !important;
    font-weight: 600;
    font-size: var(--t-sm) !important;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: var(--bone);
    /* Force dark text: the more-specific `.drawer-links a` rule sets color to
       var(--bone), which would otherwise leave cream text on a cream button
       (it read as a blank white rectangle under "about"). */
    color: var(--night) !important;
    padding: 18px !important;
    border: 0 !important;
  }
  html[data-lang="ka"] .drawer-cta {
    font-family: var(--ka) !important;
    font-style: italic !important;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-base) !important;
  }
  .drawer-lang { margin-top: auto; }

  @media (max-width: 860px) {
    .zz-nav {
      grid-template-columns: 1fr auto;
      padding: 18px 22px;
    }
    .links, .right { display: none; }
    .mobile-right { display: inline-flex; }
  }
</style>
