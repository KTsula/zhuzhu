---
import type { Package } from '~/content/packages';

interface Props {
  pkg: Package;
  variant?: 'default' | 'featured';
}
const { pkg, variant = pkg.featured ? 'featured' : 'default' } = Astro.props;
---
<article class={`pkg ${variant}`}>
  {pkg.badge && variant === 'featured' && <span class="badge">{pkg.badge}</span>}
  <p class="num">{pkg.name}</p>
  {pkg.ka && <p class="ka">{pkg.ka}</p>}
  <h4>{pkg.size}</h4>
  <p class="flavours">{pkg.flavours}</p>
  <p class="body">{pkg.blurb}</p>
  <div class="price">
    <span class="from">{pkg.priceGel ? 'From' : 'By'}</span>
    {pkg.priceGel ? (
      <>
        <b>{pkg.priceGel.toLocaleString('en-US')}</b><span class="gel">₾</span>
      </>
    ) : (
      <b>{pkg.priceLabel ?? 'quote'}</b>
    )}
  </div>
  <a href={`/book?package=${pkg.id}`} class="arrow" aria-label={`Reserve ${pkg.name}`}>→</a>
</article>

<style>
  .pkg {
    position: relative;
    padding: 40px 32px 96px;
    border: 1px solid var(--gold-hair);
    min-height: 500px;
    display: flex;
    flex-direction: column;
    background: transparent;
    transition: background 0.4s ease;
  }
  .pkg + .pkg { border-left: 0; }
  .pkg:hover {
    background:
      radial-gradient(500px 300px at 50% 0%, rgba(198, 152, 89, 0.06), transparent 70%),
      rgba(198, 152, 89, 0.02);
  }
  .pkg.featured {
    background:
      radial-gradient(ellipse at 30% 0%, rgba(198, 152, 89, 0.10), transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(138, 31, 60, 0.10), transparent 60%),
      var(--color-graphite);
    border-color: var(--gold-line);
  }
  .pkg.featured:hover {
    background:
      radial-gradient(ellipse at 30% 0%, rgba(198, 152, 89, 0.14), transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(138, 31, 60, 0.14), transparent 60%),
      var(--color-graphite);
  }

  .badge {
    position: absolute;
    top: 18px;
    right: 18px;
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--color-night);
    background: var(--color-gold);
    padding: 6px 10px;
    border-radius: 999px;
  }

  .num {
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-gold);
    font-size: 12px;
    letter-spacing: 0.24em;
  }
  .ka {
    margin-top: 6px;
    font-family: var(--font-ka);
    font-style: italic;
    color: var(--color-gold-bright);
    font-size: 16px;
  }
  h4 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 34px;
    line-height: 1.05;
    margin: 24px 0 14px;
    letter-spacing: -0.005em;
    color: var(--color-bone);
  }
  .flavours {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--color-wine-glow);
    margin-bottom: 10px;
  }
  .body {
    font-size: 17px;
    color: var(--color-bone-warm);
    line-height: 1.6;
    max-width: 260px;
  }

  .price {
    margin-top: auto;
    padding-top: 26px;
    display: flex;
    align-items: baseline;
    gap: 10px;
    color: var(--color-bone);
    font-family: var(--font-serif);
  }
  .price .from {
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 11.5px;
    letter-spacing: 0.22em;
    color: var(--color-ash-dim);
  }
  .price b {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 32px;
    font-weight: 500;
    color: var(--color-gold-bright);
    letter-spacing: -0.005em;
  }
  .price .gel {
    font-size: 22px;
    color: var(--color-gold);
    font-weight: 500;
    font-style: italic;
  }

  .arrow {
    position: absolute;
    bottom: 28px;
    left: 32px;
    width: 40px;
    height: 40px;
    border: 1px solid var(--gold-line);
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: var(--color-gold-bright);
    transition: all 0.3s ease;
    font-size: 16px;
  }
  .pkg:hover .arrow {
    border-color: var(--color-gold);
    transform: rotate(-45deg);
    background: var(--color-gold);
    color: var(--color-night);
  }
</style>
