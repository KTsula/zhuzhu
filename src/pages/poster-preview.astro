---
// Preview page for the stand poster. Not linked from nav/sitemap — local
// design surface only. Safe to delete once the poster ships to the printer.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZhuZhu — Stand poster preview</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600&family=Spectral:ital,wght@0,300;1,300;1,400&family=Noto+Serif+Georgian:wght@400&display=swap" />
    <style>
      :root {
        --night: #0a0706;
        --graphite: #14100d;
        --bone: #ede1c4;
        --bone-warm: #e3d3ab;
        --ash: #b3a48a;
        --gold: #c69859;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--graphite);
        color: var(--bone);
        font-family: Manrope, sans-serif;
        min-height: 100vh;
      }
      .page { max-width: 920px; margin: 0 auto; padding: 56px 24px 80px; }
      header { text-align: center; margin-bottom: 48px; }
      h1 {
        font-family: Spectral, Georgia, serif;
        font-style: italic; font-weight: 300;
        font-size: clamp(28px, 4vw, 40px);
        margin: 0;
        letter-spacing: -0.01em;
      }
      .meta { margin-top: 16px; color: var(--ash); font-size: 14px; letter-spacing: 0.04em; }
      .poster-wrap {
        display: flex; flex-direction: column;
        gap: 14px; align-items: center;
      }
      .poster {
        width: 100%;
        max-width: 560px;
        aspect-ratio: 297 / 420;
        background: var(--night);
        box-shadow:
          0 32px 90px rgba(0, 0, 0, 0.55),
          0 6px 18px rgba(0, 0, 0, 0.65),
          0 0 0 1px rgba(198, 152, 89, 0.10);
        display: block;
        object-fit: contain;
      }
      .label {
        font-family: Manrope, sans-serif;
        font-weight: 500; font-size: 12px;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--gold);
      }
      .scale-note {
        text-align: center; margin-top: 40px;
        color: var(--ash); font-size: 13px; line-height: 1.6;
        max-width: 60ch; margin-left: auto; margin-right: auto;
      }
      .scale-note em { font-family: Spectral, Georgia, serif; font-style: italic; font-weight: 300; }
      @media (max-width: 720px) {
        .page { padding: 36px 16px 60px; }
        header { margin-bottom: 32px; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header>
        <h1>Stand poster</h1>
        <p class="meta">A3 portrait · 297 × 420 mm · 3 mm bleed</p>
      </header>

      <div class="poster-wrap">
        <img class="poster" src="/posters/zhuzhu-stand.png" alt="ZhuZhu stand poster" />
        <div class="label">ZhuZhu — Tbilisi Gastro Week stand sheet</div>
      </div>

      <p class="scale-note">
        Prints at A3. Mount it on the easel beside the cube display. The
        QR routes to <em>/tasted-us?at=gastro-week-2026</em> — same
        landing the event QR card already points at.
      </p>
    </div>
  </body>
</html>
