---
import { booking, whatsapp } from '../content/copy';
const f = booking.en.fields;
const fk = booking.ka.fields;
---
<section class="zz-booking" id="book">
  <div class="grid">
    <aside class="left">
      <h2 class="head display">
        <span class="lng-en">{booking.en.head}</span>
        <span class="lng-ka">{booking.ka.head}</span>
      </h2>
      <p class="sub">
        <span class="lng-en">{booking.en.sub}</span>
        <span class="lng-ka">{booking.ka.sub}</span>
      </p>
      <p class="min-order">
        <span class="lng-en">{booking.en.minOrder}</span>
        <span class="lng-ka">{booking.ka.minOrder}</span>
      </p>
      <a href="mailto:hello@zhuzhu.ge" class="mail">hello@zhuzhu.ge</a>

      <div class="wa">
        <span class="wa-lead">
          <span class="lng-en">{booking.en.whatsappLead}</span>
          <span class="lng-ka">{booking.ka.whatsappLead}</span>
        </span>
        <a class="wa-btn" href={whatsapp.href} target="_blank" rel="noopener noreferrer">
          <svg class="wa-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01ZM12.05 20.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.39c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.24 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"/>
          </svg>
          <span class="lng-en">{booking.en.whatsappCta}</span>
          <span class="lng-ka">{booking.ka.whatsappCta}</span>
        </a>
        <span class="wa-num">{whatsapp.number}</span>
      </div>
    </aside>

    <form class="form" id="zz-booking-form" novalidate>
      <div class="two">
        <div class="field">
          <label class="lng-en">{f.name.label}</label>
          <label class="lng-ka">{fk.name.label}</label>
          <input type="text" name="name" required autocomplete="name" />
        </div>
        <div class="field">
          <label class="lng-en">{f.phone.label}</label>
          <label class="lng-ka">{fk.phone.label}</label>
          <input type="tel" name="phone" required autocomplete="tel" inputmode="tel" />
        </div>
      </div>

      <div class="field">
        <label class="lng-en">{f.email.label}</label>
        <label class="lng-ka">{fk.email.label}</label>
        <input type="email" name="email" autocomplete="email" inputmode="email" />
      </div>

      <div class="two">
        <div class="field">
          <label class="lng-en">{f.date.label}</label>
          <label class="lng-ka">{fk.date.label}</label>
          <input type="text" name="date" id="zz-booking-date" autocomplete="off" />
        </div>
        <div class="field">
          <label class="lng-en">{f.guests.label}</label>
          <label class="lng-ka">{fk.guests.label}</label>
          <input type="text" name="guests" inputmode="numeric" />
        </div>
      </div>

      <div class="field">
        <label class="lng-en">{f.venue.label}</label>
        <label class="lng-ka">{fk.venue.label}</label>
        <input type="text" name="venue" />
      </div>

      <div class="field">
        <label class="lng-en">{f.note.label}</label>
        <label class="lng-ka">{fk.note.label}</label>
        <textarea name="note"></textarea>
      </div>

      <p class="tasting-note">
        <span class="lng-en">{booking.en.tasting}</span>
        <span class="lng-ka">{booking.ka.tasting}</span>
      </p>

      <div class="bottom">
        <span class="foot">
          <span class="lng-en">{booking.en.foot}</span>
          <span class="lng-ka">{booking.ka.foot}</span>
        </span>
        <button class="cta submit" type="submit" id="zz-booking-submit">
          <span class="lng-en">{booking.en.submit}</span>
          <span class="lng-ka">{booking.ka.submit}</span>
        </button>
      </div>

      <div class="result" id="zz-booking-result" data-state="idle"></div>
    </form>
  </div>
</section>

<script is:inline define:vars={{
  enSubmit: booking.en.submit,
  enSending: booking.en.sending,
  enSuccess: booking.en.success,
  enFailure: booking.en.failure,
  kaSubmit: booking.ka.submit,
  kaSending: booking.ka.sending,
  kaSuccess: booking.ka.success,
  kaFailure: booking.ka.failure,
}}>
  (function () {
    const form = document.getElementById('zz-booking-form');
    const btn  = document.getElementById('zz-booking-submit');
    const out  = document.getElementById('zz-booking-result');
    if (!form || !btn || !out) return;

    function t(en, ka) {
      const lang = document.documentElement.getAttribute('data-lang') === 'ka' ? 'ka' : 'en';
      return lang === 'ka' ? ka : en;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const payload = {
        name: String(data.get('name') || ''),
        phone: String(data.get('phone') || ''),
        email: String(data.get('email') || ''),
        date: String(data.get('date') || ''),
        guests: String(data.get('guests') || ''),
        venue: String(data.get('venue') || ''),
        note: String(data.get('note') || ''),
        lang: document.documentElement.getAttribute('data-lang') || 'en',
      };
      // Require name + phone before sending.
      if (!payload.name.trim() || !payload.phone.trim()) {
        out.dataset.state = 'error';
        out.textContent = t(enFailure, kaFailure);
        const firstEmpty = !payload.name.trim() ? form.querySelector('[name="name"]') : form.querySelector('[name="phone"]');
        if (firstEmpty) firstEmpty.focus();
        return;
      }
      btn.disabled = true;
      btn.textContent = t(enSending, kaSending);
      out.dataset.state = 'sending';
      out.textContent = '';
      try {
        const res = await fetch('/api/book', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('bad status ' + res.status);
        out.dataset.state = 'success';
        out.textContent = t(enSuccess, kaSuccess);
        form.reset();
        btn.textContent = t(enSubmit, kaSubmit);
        btn.disabled = false;
      } catch {
        out.dataset.state = 'error';
        out.textContent = t(enFailure, kaFailure);
        btn.textContent = t(enSubmit, kaSubmit);
        btn.disabled = false;
      }
    });
  })();
</script>

<script>
  import flatpickr from 'flatpickr';
  import { Georgian } from 'flatpickr/dist/l10n/ka.js';
  import 'flatpickr/dist/flatpickr.css';

  (function () {
    const input = document.getElementById('zz-booking-date');
    if (!input) return;

    const build = () => {
      const ka = document.documentElement.getAttribute('data-lang') === 'ka';
      return flatpickr(input, {
        dateFormat: 'j F Y',
        minDate: 'today',
        disableMobile: true,
        monthSelectorType: 'static',
        locale: ka ? Georgian : 'default',
        onReady: (_dates, _str, fp) => fp.calendarContainer.classList.add('zz-cal'),
      });
    };

    let fp = build();
    document.addEventListener('langchange', () => {
      const picked = fp.selectedDates[0];
      fp.destroy();
      fp = build();
      if (picked) fp.setDate(picked, true);
    });
  })();
</script>

<style is:global>
  /* Flatpickr calendar — themed to the ZhuZhu palette. The popup is appended
     to <body>, so these rules are global, scoped via the .zz-cal class added on ready. */
  .zz-cal.flatpickr-calendar {
    background: var(--graphite);
    border: 1px solid rgba(198, 152, 89, 0.3);
    border-radius: 0;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    font-family: var(--body);
  }
  .zz-cal.flatpickr-calendar.arrowTop::before,
  .zz-cal.flatpickr-calendar.arrowTop::after,
  .zz-cal.flatpickr-calendar.arrowBottom::before,
  .zz-cal.flatpickr-calendar.arrowBottom::after { display: none; }

  .zz-cal .flatpickr-months,
  .zz-cal .flatpickr-month { background: transparent; color: var(--bone); fill: var(--bone); }
  .zz-cal .flatpickr-current-month input.cur-year { color: var(--bone); }
  .zz-cal .flatpickr-monthDropdown-months { background: var(--graphite); color: var(--bone); font-weight: 500; }
  .zz-cal .flatpickr-prev-month svg,
  .zz-cal .flatpickr-next-month svg { fill: var(--ash); }
  .zz-cal .flatpickr-prev-month:hover svg,
  .zz-cal .flatpickr-next-month:hover svg { fill: var(--gold-bright); }

  .zz-cal span.flatpickr-weekday { background: transparent; color: var(--ash); font-weight: 600; }
  .zz-cal .flatpickr-day { color: var(--bone); border-radius: 0; border: 1px solid transparent; }
  .zz-cal .flatpickr-day:hover { background: rgba(198, 152, 89, 0.15); border-color: transparent; }
  .zz-cal .flatpickr-day.today { border-color: var(--gold); }
  .zz-cal .flatpickr-day.selected,
  .zz-cal .flatpickr-day.selected:hover {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--night);
    font-weight: 600;
  }
  .zz-cal .flatpickr-day.flatpickr-disabled,
  .zz-cal .flatpickr-day.prevMonthDay,
  .zz-cal .flatpickr-day.nextMonthDay { color: var(--ash-dim); }
  .zz-cal .flatpickr-day.flatpickr-disabled { color: rgba(131, 117, 96, 0.35); }
  .zz-cal .numInputWrapper span.arrowUp::after { border-bottom-color: var(--ash); }
  .zz-cal .numInputWrapper span.arrowDown::after { border-top-color: var(--ash); }
</style>

<style>
  .zz-booking {
    padding: 120px 24px 140px;
    background: var(--night);
    scroll-margin-top: 80px;
  }
  .grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 96px;
    align-items: start;
  }
  .left .head {
    font-size: var(--t-2xl);
    margin: 0;
  }
  .left .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    margin: 28px 0 32px;
    max-width: 38ch;
    line-height: 1.6;
  }
  html[data-lang="ka"] .left .sub { font-family: var(--ka); font-weight: 400; }
  .left .mail {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-base);
    color: var(--bone);
    border-bottom: 1px solid var(--gold);
    padding-bottom: 6px;
    transition: color 0.3s var(--ease-out-quart), border-color 0.3s var(--ease-out-quart);
  }
  .left .mail:hover { color: var(--gold-bright); border-color: var(--gold-bright); }

  .min-order {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-sm);
    color: var(--gold-bright);
    letter-spacing: 0.02em;
    margin: -12px 0 28px;
  }
  html[data-lang="ka"] .min-order { font-family: var(--ka); font-weight: 400; }

  .wa {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(198,152,89,0.18);
  }
  .wa-lead {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-sm);
    color: var(--ash);
  }
  html[data-lang="ka"] .wa-lead { font-family: var(--ka); font-weight: 400; }
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--night);
    background: var(--gold);
    padding: 12px 20px;
    transition: background 0.3s var(--ease-out-quart);
  }
  .wa-btn:hover { background: var(--gold-bright); }
  .wa-icon { flex-shrink: 0; }
  html[data-lang="ka"] .wa-btn {
    font-family: var(--ka);
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-base);
  }
  .wa-num {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--bone-warm);
    letter-spacing: 0.04em;
  }

  .form { display: flex; flex-direction: column; gap: 32px; }
  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .field { display: flex; flex-direction: column; gap: 10px; }
  .field label {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
  }
  html[data-lang="ka"] .field label {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 14px 0;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(198,152,89,0.3);
    color: var(--bone);
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-base);
    border-radius: 0;
    transition: border-color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .field input,
  html[data-lang="ka"] .field textarea { font-family: var(--ka); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: var(--gold);
  }
  .field textarea {
    min-height: 100px;
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--ash-dim); }

  .bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 8px;
  }
  .foot {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-sm);
    color: var(--ash);
    max-width: 36ch;
  }
  html[data-lang="ka"] .foot { font-family: var(--ka); font-weight: 400; font-size: var(--t-base); }

  .tasting-note {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-xs);
    color: var(--ash-dim);
    line-height: 1.5;
    max-width: 52ch;
    margin: -12px 0 0;
  }
  html[data-lang="ka"] .tasting-note { font-family: var(--ka); font-weight: 400; font-size: var(--t-sm); }

  .result {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    line-height: 1.5;
    padding: 16px 18px;
    margin-top: 8px;
    background: transparent;
  }
  html[data-lang="ka"] .result { font-family: var(--ka); }
  .result[data-state="idle"] { display: none; }
  .result[data-state="sending"] { color: var(--ash); background: rgba(198,152,89,0.06); }
  .result[data-state="success"] { color: var(--bone); background: rgba(227,183,109,0.10); }
  .result[data-state="error"]   { color: var(--bone); background: rgba(183,58,90,0.12); }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; gap: 56px; }
  }
  @media (max-width: 720px) {
    .zz-booking { padding: 80px 22px 96px; }
    .two { grid-template-columns: 1fr; gap: 24px; }
    .bottom { flex-direction: column-reverse; align-items: stretch; }
    .submit { width: 100%; }
  }
</style>
