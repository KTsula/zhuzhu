---
import Base from '../layouts/Base.astro';
import { contactPage, footer, whatsapp, pageMeta } from '../content/copy';
---
<Base current="contact"
      title={pageMeta.contact.en.title}
      description={pageMeta.contact.en.desc}>

  <section class="contact">
    <header class="head">
      <div class="eyebrow label">
        <span class="lng-en">{contactPage.en.eyebrow}</span>
        <span class="lng-ka">{contactPage.ka.eyebrow}</span>
      </div>
      <h1 class="display title">
        <span class="lng-en">{contactPage.en.head}</span>
        <span class="lng-ka">{contactPage.ka.head}</span>
      </h1>
      <p class="sub">
        <span class="lng-en">{contactPage.en.sub}</span>
        <span class="lng-ka">{contactPage.ka.sub}</span>
      </p>
    </header>

    <hr class="hairline" />

    <!-- WhatsApp — primary action -->
    <article class="channel channel-primary">
      <div class="channel-meta">
        <div class="ch-label">
          <svg class="ch-icon" width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
            <path fill="currentColor" d="M16 3C9 3 3.4 8.6 3.4 15.5c0 2.4.7 4.7 1.9 6.7L3 29l7-1.8c1.9 1 4 1.6 6.1 1.6 6.9 0 12.6-5.6 12.6-12.5C28.6 8.6 23 3 16 3Zm0 22.7c-1.9 0-3.8-.5-5.4-1.5l-.4-.2-4.2 1.1 1.1-4.1-.3-.4a10.2 10.2 0 1 1 9.2 5.1Zm5.7-7.7c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.5-1.6-.9-.8-1.5-1.8-1.7-2.2-.2-.3 0-.5.1-.7l.5-.6c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.8-1.9c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3 4.9 4.2 2.8 1.2 2.8.8 3.3.8.5 0 1.7-.7 2-1.4.3-.7.3-1.2.2-1.4Z"/>
          </svg>
          <span class="lng-en">{contactPage.en.waLabel}</span>
          <span class="lng-ka">{contactPage.ka.waLabel}</span>
        </div>
        <p class="ch-note">
          <span class="lng-en">{contactPage.en.waNote}</span>
          <span class="lng-ka">{contactPage.ka.waNote}</span>
        </p>
        <div class="ch-digits">{whatsapp.number}</div>
      </div>
      <a class="ch-cta cta" href={whatsapp.href} target="_blank" rel="noopener noreferrer">
        <span class="lng-en">{contactPage.en.waCta}</span>
        <span class="lng-ka">{contactPage.ka.waCta}</span>
      </a>
    </article>

    <!-- Email — second -->
    <article class="channel">
      <div class="channel-meta">
        <div class="ch-label">
          <svg class="ch-icon" width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" d="M4 8h24v16H4z"/>
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" d="M4 8l12 9 12-9"/>
          </svg>
          <span class="lng-en">{contactPage.en.emailLabel}</span>
          <span class="lng-ka">{contactPage.ka.emailLabel}</span>
        </div>
        <p class="ch-note">
          <span class="lng-en">{contactPage.en.emailNote}</span>
          <span class="lng-ka">{contactPage.ka.emailNote}</span>
        </p>
        <div class="ch-digits">{contactPage.en.emailCta}</div>
      </div>
      <a class="ch-cta cta-ghost" href={`mailto:${contactPage.en.emailCta}`}>
        <span class="lng-en">{contactPage.en.emailCta}</span>
        <span class="lng-ka">{contactPage.ka.emailCta}</span>
      </a>
    </article>

    <hr class="hairline" />

    <!-- Socials -->
    <section class="socials-block">
      <div class="socials-meta">
        <div class="label">
          <span class="lng-en">{contactPage.en.socialLabel}</span>
          <span class="lng-ka">{contactPage.ka.socialLabel}</span>
        </div>
        <p class="ch-note">
          <span class="lng-en">{contactPage.en.socialNote}</span>
          <span class="lng-ka">{contactPage.ka.socialNote}</span>
        </p>
      </div>
      <div class="socials">
        {footer.en.socials.map((s, i) => (
          <a class="social" href={s.href} target="_blank" rel="noopener noreferrer">
            <span class="lng-en">{s.label}</span>
            <span class="lng-ka">{footer.ka.socials[i]?.label ?? s.label}</span>
            <span class="social-arrow" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </section>

    <hr class="hairline" />

    <!-- Atelier address -->
    <section class="addr">
      <div class="label">
        <span class="lng-en">{contactPage.en.addrHead}</span>
        <span class="lng-ka">{contactPage.ka.addrHead}</span>
      </div>
      <div class="addr-lines">
        <div class="lng-en">{contactPage.en.addrLines.map((l) => <div>{l}</div>)}</div>
        <div class="lng-ka">{contactPage.ka.addrLines.map((l) => <div>{l}</div>)}</div>
      </div>
    </section>
  </section>
</Base>

<style>
  .contact {
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 24px 120px;
  }
  .head { text-align: center; }
  .eyebrow { display: inline-block; }
  .title {
    font-size: var(--t-3xl);
    margin: 18px 0 22px;
    line-height: 1.1;
  }
  .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 36ch;
  }
  html[data-lang="ka"] .sub { font-family: var(--ka); font-weight: 400; }

  hr.hairline { margin: 56px 0; }

  /* ── Channels ──────────────────────────────────────────── */
  .channel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 36px;
    align-items: center;
    padding: 28px 0;
  }
  .channel + .channel { border-top: 1px solid rgba(198,152,89,0.16); }
  .channel.muted { opacity: 0.55; }
  .channel.muted .ch-cta { pointer-events: none; cursor: default; }

  .channel-meta { display: flex; flex-direction: column; gap: 8px; }
  .ch-label {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ash);
  }
  html[data-lang="ka"] .ch-label {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .ch-icon { color: var(--gold); }
  .channel-primary .ch-icon { color: var(--gold-bright); }

  .ch-note {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.55;
    margin: 0;
    max-width: 42ch;
  }
  html[data-lang="ka"] .ch-note { font-family: var(--ka); font-weight: 400; }

  .ch-digits {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-lg);
    color: var(--bone);
    letter-spacing: -0.005em;
    margin-top: 4px;
  }
  html[data-lang="ka"] .ch-digits { font-family: var(--ka); }

  .ch-cta { white-space: nowrap; }

  /* ── Socials ──────────────────────────────────────────── */
  .socials-block { display: flex; flex-direction: column; gap: 24px; }
  .socials-meta { display: flex; flex-direction: column; gap: 8px; }
  .socials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .social {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 22px;
    border: 1px solid rgba(198,152,89,0.20);
    color: var(--bone);
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition:
      background 0.3s var(--ease-out-quart),
      border-color 0.3s var(--ease-out-quart),
      color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .social {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-base);
  }
  .social:hover {
    background: rgba(198,152,89,0.08);
    border-color: var(--gold);
    color: var(--gold-bright);
  }
  .social-arrow {
    font-family: var(--display);
    font-weight: 300;
    font-style: normal;
    font-size: var(--t-base);
    color: var(--gold);
    transition: transform 0.3s var(--ease-out-quart);
  }
  .social:hover .social-arrow { transform: translate(2px, -2px); }

  /* ── Atelier address ──────────────────────────────────── */
  .addr {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: center;
    align-items: center;
  }
  .addr-lines {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.4;
  }
  html[data-lang="ka"] .addr-lines { font-family: var(--ka); }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 720px) {
    .contact { padding: 80px 22px 90px; }
    hr.hairline { margin: 44px 0; }
    .channel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .ch-cta { width: 100%; text-align: center; justify-content: center; }
    .socials { grid-template-columns: 1fr; }
  }
</style>
