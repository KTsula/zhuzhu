---
import { packages, packageList, signatures } from '../content/copy';
---
<section class="zz-packages">
  <header class="head">
    <h2 class="display title">
      <span class="lng-en">Suggested boxes.</span>
      <span class="lng-ka">შემოთავაზებული ყუთები.</span>
    </h2>
    <p class="sub">
      <span class="lng-en">{packages.en.sub}</span>
      <span class="lng-ka">{packages.ka.sub}</span>
    </p>
  </header>

  <div class="rows">
    {packageList.map((p) => {
      const items = signatures
        .map((f) => ({ ...f, count: p.counts[f.id] || 0 }))
        .filter((f) => f.count > 0);
      return (
        <article class="row">
          <div class="row-head">
            <div class="row-left">
              <div class="row-meta">
                <span class="row-no">{p.tag}</span>
                <span class="label">
                  <span class="lng-en">{p.fit.en}</span>
                  <span class="lng-ka">{p.fit.ka}</span>
                </span>
              </div>
              <h3 class="row-name display">
                <span class="lng-en">{p.name.en}</span>
                <span class="lng-ka">{p.name.ka}</span>
              </h3>
              <p class="row-blurb">
                <span class="lng-en">{p.blurb.en}</span>
                <span class="lng-ka">{p.blurb.ka}</span>
              </p>
            </div>
            <div class="row-right">
              <div class="price">₾{p.total}</div>
              <div class="cubes-info">
                <span class="lng-en">{p.cubes} cubes</span>
                <span class="lng-ka">{p.cubes} კუბი</span>
              </div>
            </div>
          </div>
          <div class="row-cubes">
            {items.map((f) => (
              <span class="cube-chip">
                {f.count}× <span class="lng-en">{f.name.en}</span><span class="lng-ka">{f.name.ka}</span>
              </span>
            ))}
          </div>
          <div class="row-cta-wrap">
            <a class="cta-ghost" href="/#book">
              <span class="lng-en">{p.cta.en}</span>
              <span class="lng-ka">{p.cta.ka}</span>
            </a>
          </div>
        </article>
      );
    })}
  </div>

  <footer class="foot">
    <p class="foot-note">
      <span class="lng-en">{packages.en.buildNote}</span>
      <span class="lng-ka">{packages.ka.buildNote}</span>
    </p>
  </footer>
</section>

<style>
  .zz-packages {
    padding: 120px 40px;
    background: var(--night);
    max-width: 1100px;
    margin: 0 auto;
  }
  .head { margin-bottom: 72px; max-width: 720px; }
  .head .title {
    font-size: var(--t-3xl);
    margin: 0;
  }
  .head .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    margin: 24px 0 0;
    max-width: 56ch;
  }
  html[data-lang="ka"] .head .sub { font-family: var(--ka); font-weight: 400; }

  .rows { display: flex; flex-direction: column; }
  .row {
    padding: 48px 0;
    border-top: 1px solid rgba(198,152,89,0.15);
    display: grid;
    gap: 32px;
  }
  .row:last-child { border-bottom: 1px solid rgba(198,152,89,0.15); }
  .row-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 56px;
    align-items: baseline;
  }
  .row-meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 16px;
  }
  .row-no {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-lg);
    color: var(--gold);
  }
  .row-name {
    margin: 0;
    font-size: var(--t-2xl);
  }
  .row-blurb {
    margin: 18px 0 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    max-width: 50ch;
  }
  html[data-lang="ka"] .row-blurb { font-family: var(--ka); font-weight: 400; }
  .row-right { text-align: right; }
  .price {
    font-family: var(--display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--t-3xl);
    color: var(--bone);
    line-height: 1;
  }
  .cubes-info {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--ash);
    margin-top: 6px;
  }
  html[data-lang="ka"] .cubes-info { font-family: var(--ka); }

  .row-cubes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
  }
  .cube-chip {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--ash);
  }
  html[data-lang="ka"] .cube-chip { font-family: var(--ka); }
  .row-cta-wrap { display: flex; }

  .foot { margin-top: 56px; }
  .foot-note {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--ash);
    line-height: 1.65;
    max-width: 56ch;
    margin: 0;
  }
  html[data-lang="ka"] .foot-note { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 720px) {
    .zz-packages { padding: 80px 22px; }
    .head { margin-bottom: 48px; }
    .row { padding: 36px 0; }
    .row-head { grid-template-columns: 1fr; gap: 24px; }
    .row-right { text-align: left; }
  }
</style>
