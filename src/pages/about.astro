---
import Base from '../layouts/Base.astro';

const origin = {
  en: [
    'ZhuZhu began on a winter night, when three friends, a chef, a food chemist and a builder, kept ending up in the same kitchen and pouring the last of the Saperavi into whatever else was on the table.',
    'One of those wines, set the next morning in a small glass tray, became the first cube. It tasted like a cocktail and ate like a dessert.',
    'Three years on we set cocktail desserts by hand. Weddings, brand evenings, hotel menus, the occasional private dinner that asked us not to tell anyone we came.',
  ],
  ka: [
    'ჟუჟუ ერთ ზამთრის საღამოს დაიწყო, როცა სამი მეგობარი, შეფი, საკვების ქიმიკოსი და მშენებელი, ერთსა და იმავე სამზარეულოში აღმოჩნდნენ და საფერავის ბოლო წვეთებს თეფშზე დარჩენილ ყველაფერში ასხამდნენ.',
    'ერთ-ერთი ეს ღვინო, მეორე დილით პატარა მინის თეფშზე დაყენებული, პირველი კუბი გახდა. გემოვნება იყო კოქტეილის, ჭამდი როგორც დესერტს.',
    'სამი წლის შემდეგ კოქტეილ-დესერტებს ხელით ვაყენებთ. ქორწილებისთვის, ბრენდის საღამოებისთვის, სასტუმროების მენიუებისთვის და ხანდახან იმ პრივატული სადილისთვის, რომელიც გვთხოვა, არავის ვუთხრათ რომ მოვედით.',
  ],
};

const founders = [
  {
    name: { en: 'Keti', ka: 'ქეთი' },
    role: { en: 'Site, business, photography', ka: 'საიტი, ბიზნესი, ფოტოგრაფია' },
    bio: {
      en: 'The site, the pricing, the lens. Keti runs the brand surface. What the world sees and what it clicks.',
      ka: 'საიტი, ფასები, ობიექტივი. ქეთი მართავს ბრენდის ზედაპირს. რასაც სამყარო ხედავს და რასაც აჭერს.',
    },
    accent: 'rgba(196, 140, 70, 0.30)',
  },
  {
    name: { en: 'Anna', ka: 'ანა' },
    role: { en: 'Food chemistry, compliance, kitchen', ka: 'ქიმია, შესაბამისობა, სამზარეულო' },
    bio: {
      en: 'The gelatine, the acid, the law. Anna keeps the cube together and the kitchen on the right side of HACCP.',
      ka: 'ჟელატინი, მჟავა, კანონი. ანა აერთიანებს კუბს და სამზარეულოს ინახავს HACCP-ის სწორ მხარეს.',
    },
    accent: 'rgba(220, 170, 70, 0.32)',
  },
  {
    name: { en: 'Lado', ka: 'ლადო' },
    role: { en: 'Chef, recipes, production', ka: 'შეფი, რეცეპტები, წარმოება' },
    bio: {
      en: 'The recipes, the heat, the taste. Lado owns the food itself: every cube on every tray.',
      ka: 'რეცეპტები, სითბო, გემო. ლადო ფლობს თვით საკვებს: ყოველი თეფშის ყოველი კუბი.',
    },
    accent: 'rgba(180, 50, 80, 0.30)',
  },
];
---
<Base current="about"
      title="About. ZhuZhu, cocktail desserts."
      description="Three founders, one kitchen, two nights a week. The ZhuZhu origin.">
  <section class="origin">
    <h1 class="display title">
      <span class="lng-en">Three founders.<br>One kitchen.</span>
      <span class="lng-ka">სამი დამფუძნებელი.<br>ერთი სამზარეულო.</span>
    </h1>
    <div class="paras lng-en">{origin.en.map((p) => <p>{p}</p>)}</div>
    <div class="paras lng-ka">{origin.ka.map((p) => <p>{p}</p>)}</div>
  </section>

  <section class="founders-section">
    <div class="founders">
      {founders.map((f) => (
        <article class="founder">
          <div class="vignette">
            <div class="glow" style={`background: radial-gradient(60% 50% at 50% 55%, ${f.accent} 0%, rgba(10,7,6,0) 72%)`}></div>
          </div>
          <h3 class="name display">
            <span class="lng-en">{f.name.en}</span>
            <span class="lng-ka">{f.name.ka}</span>
          </h3>
          <div class="role">
            <span class="lng-en">{f.role.en}</span>
            <span class="lng-ka">{f.role.ka}</span>
          </div>
          <p class="bio">
            <span class="lng-en">{f.bio.en}</span>
            <span class="lng-ka">{f.bio.ka}</span>
          </p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .origin {
    padding: 140px 24px 110px;
    background: var(--night);
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .origin .title {
    font-size: var(--t-3xl);
    margin: 0;
    line-height: 1.15;
  }
  .paras { margin-top: 64px; text-align: left; }
  .paras p {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.7;
    margin: 0 0 24px;
    max-width: 60ch;
  }
  html[data-lang="ka"] .paras p { font-family: var(--ka); font-weight: 400; }

  .founders-section {
    padding: 100px 40px;
    background: var(--night);
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .founders {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 64px;
  }
  .founder { display: flex; flex-direction: column; gap: 18px; }
  .vignette {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--night);
    overflow: hidden;
    border-bottom: 1px solid rgba(198,152,89,0.18);
  }
  .vignette .glow { position: absolute; inset: 0; }
  .name {
    margin: 8px 0 0;
    font-size: var(--t-xl);
  }
  .role {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ash);
  }
  html[data-lang="ka"] .role {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .bio {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    margin: 0;
  }
  html[data-lang="ka"] .bio { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 1024px) {
    .founders { grid-template-columns: 1fr; gap: 56px; }
  }
  @media (max-width: 720px) {
    .origin { padding: 80px 22px 64px; }
    .paras { margin-top: 40px; }
    .founders-section { padding: 64px 22px; }
  }
</style>
