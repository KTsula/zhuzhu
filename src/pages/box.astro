---
import Base from '../layouts/Base.astro';
import { boxPage, pageMeta } from '../content/copy';
---
<Base current="box"
      title={pageMeta.box.en.title}
      description={pageMeta.box.en.desc}>
  <section class="zz-box-hero">
    <span class="eyebrow label">
      <span class="lng-en">{boxPage.en.eyebrow}</span>
      <span class="lng-ka">{boxPage.ka.eyebrow}</span>
    </span>

    <h1 class="display head">
      <span class="lng-en">{boxPage.en.head}</span>
      <span class="lng-ka">{boxPage.ka.head}</span>
    </h1>

    <p class="sub">
      <span class="lng-en">{boxPage.en.sub}</span>
      <span class="lng-ka">{boxPage.ka.sub}</span>
    </p>

    <div class="box-note">
      <span class="lng-en">{boxPage.en.note}</span>
      <span class="lng-ka">{boxPage.ka.note}</span>
    </div>

    <form class="waitlist" id="zz-waitlist" novalidate>
      <div class="wl-row">
        <input type="email" name="email" required autocomplete="email" inputmode="email"
               data-ph-en={boxPage.en.emailPh} data-ph-ka={boxPage.ka.emailPh}
               placeholder={boxPage.en.emailPh} aria-label="email" />
        <button type="submit" class="cta" id="zz-waitlist-btn">
          <span class="lng-en">{boxPage.en.cta}</span>
          <span class="lng-ka">{boxPage.ka.cta}</span>
        </button>
      </div>
      <p class="wl-note">
        <span class="lng-en">{boxPage.en.waitlistNote}</span>
        <span class="lng-ka">{boxPage.ka.waitlistNote}</span>
      </p>
      <div class="wl-result" id="zz-waitlist-result" data-state="idle"></div>
    </form>
  </section>

  <section class="zz-box-steps">
    <h2 class="display steps-head">
      <span class="lng-en">{boxPage.en.stepsHead}</span>
      <span class="lng-ka">{boxPage.ka.stepsHead}</span>
    </h2>

    <ol class="steps">
      {boxPage.en.steps.map((s, i) => {
        const ka = boxPage.ka.steps[i];
        return (
          <li class="step">
            <span class="n">{s.n}</span>
            <div class="body">
              <h3 class="name">
                <span class="lng-en">{s.name}</span>
                <span class="lng-ka">{ka.name}</span>
              </h3>
              <p class="d">
                <span class="lng-en">{s.d}</span>
                <span class="lng-ka">{ka.d}</span>
              </p>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="zz-box-final">
    <h2 class="display final-head">
      <span class="lng-en">{boxPage.en.finalHead}</span>
      <span class="lng-ka">{boxPage.ka.finalHead}</span>
    </h2>
    <a class="cta" href="#zz-waitlist">
      <span class="lng-en">{boxPage.en.finalCta}</span>
      <span class="lng-ka">{boxPage.ka.finalCta}</span>
    </a>
  </section>
</Base>

<script is:inline define:vars={{
  enCta: boxPage.en.cta,
  enSubmitting: boxPage.en.submitting,
  enSuccess: boxPage.en.success,
  enFailure: boxPage.en.failure,
  kaCta: boxPage.ka.cta,
  kaSubmitting: boxPage.ka.submitting,
  kaSuccess: boxPage.ka.success,
  kaFailure: boxPage.ka.failure,
}}>
  (function () {
    var form = document.getElementById('zz-waitlist');
    var btn  = document.getElementById('zz-waitlist-btn');
    var out  = document.getElementById('zz-waitlist-result');
    if (!form || !btn || !out) return;

    function lang() { return document.documentElement.getAttribute('data-lang') === 'ka' ? 'ka' : 'en'; }
    function t(en, ka) { return lang() === 'ka' ? ka : en; }

    function syncPh() {
      var L = lang();
      form.querySelectorAll('[data-ph-en],[data-ph-ka]').forEach(function (el) {
        var ph = el.getAttribute('data-ph-' + L);
        if (ph) el.setAttribute('placeholder', ph);
      });
    }
    syncPh();
    document.addEventListener('langchange', syncPh);

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var data = new FormData(form);
      var email = String(data.get('email') || '').trim().toLowerCase();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = t(enSubmitting, kaSubmitting);
      out.dataset.state = 'sending';
      out.textContent = '';

      try {
        var res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: 'box-waitlist', lang: lang() }),
        });
        if (!res.ok) throw new Error('bad status ' + res.status);
        out.dataset.state = 'success';
        out.textContent = t(enSuccess, kaSuccess);
        form.reset();
        btn.textContent = t(enCta, kaCta);
        btn.disabled = false;
      } catch (err) {
        out.dataset.state = 'error';
        out.textContent = t(enFailure, kaFailure);
        btn.textContent = t(enCta, kaCta);
        btn.disabled = false;
      }
    });
  })();
</script>

<style>
  .zz-box-hero {
    padding: 140px 24px 100px;
    background: var(--night);
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .zz-box-hero .eyebrow {
    display: block;
    color: var(--gold);
    margin-bottom: 28px;
  }
  .zz-box-hero .head {
    font-size: var(--t-display);
    margin: 0;
  }
  .zz-box-hero .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 46ch;
    margin: 36px auto 0;
  }
  html[data-lang="ka"] .zz-box-hero .sub { font-family: var(--ka); font-weight: 400; }

  .box-note {
    display: inline-flex;
    margin: 44px auto 0;
    padding: 16px 28px;
    border-top: 1px solid rgba(198,152,89,0.3);
    border-bottom: 1px solid rgba(198,152,89,0.3);
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--ash);
    letter-spacing: 0.04em;
  }
  html[data-lang="ka"] .box-note { font-family: var(--ka); font-weight: 400; }

  .waitlist {
    margin: 44px auto 0;
    max-width: 480px;
    scroll-margin-top: 90px;
  }
  .wl-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }
  .waitlist input {
    flex: 1;
    min-width: 0;
    padding: 16px 0;
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(198,152,89,0.3);
    color: var(--bone);
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-base);
    border-radius: 0;
    transition: border-color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .waitlist input { font-family: var(--ka); }
  .waitlist input::placeholder { color: var(--ash-dim); }
  .waitlist input:focus { outline: none; border-bottom-color: var(--gold); }
  .waitlist .cta { flex-shrink: 0; padding: 16px 28px; }
  .wl-note {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-xs);
    color: var(--ash-dim);
    line-height: 1.5;
    margin: 16px 0 0;
    text-align: center;
  }
  html[data-lang="ka"] .wl-note { font-family: var(--ka); font-weight: 400; font-size: var(--t-sm); }
  .wl-result {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    line-height: 1.5;
    padding: 14px 18px;
    margin-top: 14px;
    text-align: center;
  }
  html[data-lang="ka"] .wl-result { font-family: var(--ka); }
  .wl-result[data-state="idle"] { display: none; }
  .wl-result[data-state="sending"] { color: var(--ash); background: rgba(198,152,89,0.06); }
  .wl-result[data-state="success"] { color: var(--bone); background: rgba(227,183,109,0.10); }
  .wl-result[data-state="error"]   { color: var(--bone); background: rgba(183,58,90,0.12); }

  .zz-box-steps {
    padding: 110px 24px;
    background: var(--night);
    max-width: 920px;
    margin: 0 auto;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .steps-head {
    font-size: var(--t-2xl);
    margin: 0 0 56px;
    text-align: center;
  }
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1px;
    background: rgba(198,152,89,0.18);
  }
  .step {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 36px 0;
    background: var(--night);
  }
  .step .n {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-2xl);
    color: var(--gold);
    line-height: 1;
  }
  .step .name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-lg);
    color: var(--bone);
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  html[data-lang="ka"] .step .name {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 500;
  }
  .step .d {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    color: var(--bone-warm);
    line-height: 1.65;
    max-width: 58ch;
    margin: 0;
  }
  html[data-lang="ka"] .step .d { font-family: var(--ka); font-weight: 400; }

  .zz-box-final {
    padding: 140px 24px 160px;
    background: var(--night);
    text-align: center;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .final-head {
    font-size: var(--t-3xl);
    margin: 0 0 48px;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 720px) {
    .zz-box-hero { padding: 88px 22px 72px; }
    .zz-box-hero .eyebrow { margin-bottom: 20px; }
    .zz-box-hero .head { font-size: var(--t-3xl); }
    .zz-box-hero .sub { font-size: var(--t-base); margin-top: 28px; }
    .box-note {
      margin-top: 48px;
      padding: 14px 24px;
    }
    .waitlist { margin-top: 36px; }
    .wl-row { flex-direction: column; gap: 16px; }
    .waitlist .cta { width: 100%; padding: 16px 24px; }
    .zz-box-steps { padding: 72px 22px; }
    .steps-head { font-size: var(--t-xl); margin-bottom: 40px; }
    .step { grid-template-columns: 56px 1fr; gap: 20px; padding: 28px 0; }
    .step .n { font-size: var(--t-xl); }
    .step .name { font-size: var(--t-base); margin-bottom: 8px; }
    .zz-box-final { padding: 88px 22px 104px; }
    .final-head { font-size: var(--t-2xl); margin-bottom: 36px; }
  }
</style>
