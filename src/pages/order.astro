---
import Base from '../layouts/Base.astro';
import BookingForm from '../components/BookingForm.astro';
import MenuBundles from '../components/MenuBundles.astro';
import { orderPage, pageMeta, signatures, classics, menuClassics, orderFaqs, orderFaqMeta } from '../content/copy';

// FAQPage JSON-LD — Google awards rich results only when the answers
// are visible on the page. The FAQ section below renders them.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: orderFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q.en,
    acceptedAnswer: { '@type': 'Answer', text: f.a.en },
  })),
};

const rows = [
  ...signatures.map((s) => ({
    name: s.name,
    accent: s.accent,
    img: s.img,
    tag: { en: s.line.en, ka: s.line.ka },
    premium: true,
  })),
  ...classics.map((c) => ({
    name: c.name,
    accent: c.accent,
    img: null,
    tag: { en: menuClassics.en.eyebrow, ka: menuClassics.ka.eyebrow },
    premium: false,
  })),
];
---
<Base current="order"
      title={pageMeta.order.en.title}
      description={pageMeta.order.en.desc}>
  <section class="order-head">
    <h1 class="display title">
      <span class="lng-en">{orderPage.en.head}</span>
      <span class="lng-ka">{orderPage.ka.head}</span>
    </h1>
    <p class="sub">
      <span class="lng-en">{orderPage.en.sub}</span>
      <span class="lng-ka">{orderPage.ka.sub}</span>
    </p>
  </section>

  <MenuBundles />

  <section class="order-list">
    <header class="list-head">
      <span class="label">
        <span class="lng-en">{orderPage.en.flavoursEyebrow}</span>
        <span class="lng-ka">{orderPage.ka.flavoursEyebrow}</span>
      </span>
      <h2 class="display list-title">
        <span class="lng-en">{orderPage.en.flavoursHead}</span>
        <span class="lng-ka">{orderPage.ka.flavoursHead}</span>
      </h2>
      <p class="list-sub">
        <span class="lng-en">{orderPage.en.flavoursSub}</span>
        <span class="lng-ka">{orderPage.ka.flavoursSub}</span>
      </p>
    </header>

    {rows.map((r) => (
      <div class:list={["row", r.premium && 'premium']}>
        <div class="thumb">
          <div class="glow" style={`background: radial-gradient(62% 52% at 50% 55%, ${r.accent} 0%, rgba(10,7,6,0) 72%)`}></div>
          {r.img && <img src={r.img} alt={r.name.en} onerror="this.style.display='none'" />}
        </div>
        <div class="meta">
          <span class="tag">
            <span class="lng-en">{r.tag.en}</span>
            <span class="lng-ka">{r.tag.ka}</span>
          </span>
          <span class="name">
            <span class="lng-en">{r.name.en}</span>
            <span class="lng-ka">{r.name.ka}</span>
          </span>
        </div>
      </div>
    ))}
  </section>

  <section class="faq">
    <header class="faq-head">
      <span class="label">
        <span class="lng-en">{orderFaqMeta.en.eyebrow}</span>
        <span class="lng-ka">{orderFaqMeta.ka.eyebrow}</span>
      </span>
      <h2 class="display faq-title">
        <span class="lng-en">{orderFaqMeta.en.head}</span>
        <span class="lng-ka">{orderFaqMeta.ka.head}</span>
      </h2>
      <p class="faq-sub">
        <span class="lng-en">{orderFaqMeta.en.sub}</span>
        <span class="lng-ka">{orderFaqMeta.ka.sub}</span>
      </p>
    </header>

    <div class="faq-list">
      {orderFaqs.map((f) => (
        <details class="faq-item">
          <summary>
            <span class="lng-en">{f.q.en}</span>
            <span class="lng-ka">{f.q.ka}</span>
            <span class="caret" aria-hidden="true">+</span>
          </summary>
          <div class="answer">
            <span class="lng-en">{f.a.en}</span>
            <span class="lng-ka">{f.a.ka}</span>
          </div>
        </details>
      ))}
    </div>
  </section>

  <BookingForm />

  <!-- FAQPage structured data, mirroring the visible FAQ above. -->
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)}></script>
</Base>

<style>
  .order-head {
    padding: 120px 24px 72px;
    background: var(--night);
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .order-head .title { font-size: var(--t-display); margin: 0; }
  .order-head .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 48ch;
    margin: 32px auto 0;
  }
  html[data-lang="ka"] .order-head .sub { font-family: var(--ka); font-weight: 400; }

  .order-list {
    max-width: 920px;
    margin: 0 auto 40px;
    padding: 0 40px;
  }
  .list-head {
    text-align: center;
    max-width: 620px;
    margin: 88px auto 48px;
  }
  .list-head .label {
    display: block;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .list-title {
    font-size: var(--t-2xl);
    margin: 0;
  }
  .list-sub {
    margin: 20px auto 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    line-height: 1.6;
    color: var(--bone-warm);
  }
  html[data-lang="ka"] .list-sub { font-family: var(--ka); font-weight: 400; }
  .row {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 24px 0;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .row:last-child { border-bottom: 1px solid rgba(198,152,89,0.15); }

  .thumb {
    position: relative;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .thumb .glow { position: absolute; inset: 0; }
  .thumb img {
    position: absolute;
    inset: 8px;
    width: calc(100% - 16px);
    height: calc(100% - 16px);
    object-fit: contain;
  }

  .meta { flex: 1; min-width: 0; }
  .tag {
    display: block;
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 7px;
  }
  .row.premium .tag { color: var(--gold); }
  html[data-lang="ka"] .tag {
    font-family: var(--ka);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-lg);
    color: var(--bone);
  }
  html[data-lang="ka"] .name { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 720px) {
    .order-head { padding: 80px 22px 56px; }
    .order-head .sub { font-size: var(--t-base); }
    .order-list { padding: 0 22px; }
    .list-head { margin: 64px auto 36px; }
    .list-title { font-size: var(--t-xl); }
    .row { gap: 18px; padding: 20px 0; }
    .thumb { width: 48px; height: 48px; }
    .name { font-size: var(--t-base); }
  }

  /* ── FAQ ─────────────────────────────────────────────── */
  .faq {
    max-width: 760px;
    margin: 0 auto;
    padding: 100px 24px 110px;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .faq-head { text-align: center; margin-bottom: 56px; }
  .faq-title { font-size: var(--t-3xl); margin: 14px 0 18px; line-height: 1.1; }
  .faq-sub {
    font-family: var(--body); font-weight: 350; font-size: var(--t-base);
    color: var(--bone-warm); line-height: 1.55; margin: 0 auto; max-width: 42ch;
  }
  html[data-lang="ka"] .faq-sub { font-family: var(--ka); font-weight: 400; }

  .faq-list { display: flex; flex-direction: column; }
  .faq-item {
    border-top: 1px solid rgba(198,152,89,0.18);
    padding: 22px 0;
  }
  .faq-item:last-child { border-bottom: 1px solid rgba(198,152,89,0.18); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between;
    gap: 18px; cursor: pointer; list-style: none;
    font-family: var(--display);
    font-style: italic; font-weight: 300;
    font-size: var(--t-lg); color: var(--bone);
    letter-spacing: -0.005em; line-height: 1.3;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  html[data-lang="ka"] .faq-item summary { font-family: var(--ka); font-weight: 500; }
  .faq-item .caret {
    font-family: var(--body); font-weight: 300; font-size: var(--t-xl);
    color: var(--gold); transition: transform 0.3s var(--ease-out-quart);
    flex-shrink: 0;
  }
  .faq-item[open] .caret { transform: rotate(45deg); }
  .answer {
    font-family: var(--body); font-weight: 350; font-size: var(--t-base);
    color: var(--bone-warm); line-height: 1.7; margin-top: 14px; max-width: 60ch;
  }
  html[data-lang="ka"] .answer { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 720px) {
    .faq { padding: 64px 22px 80px; }
    .faq-head { margin-bottom: 36px; }
    .faq-item summary { font-size: var(--t-base); }
  }
</style>
