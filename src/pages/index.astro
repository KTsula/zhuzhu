---
import Base from '../layouts/Base.astro';
import SignatureShowcase from '../components/SignatureShowcase.astro';
import MoreFlavours from '../components/MoreFlavours.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import BookingForm from '../components/BookingForm.astro';
import { pageMeta } from '../content/copy';
---
<Base
  current="home"
  title={pageMeta.home.en.title}
  description={pageMeta.home.en.desc}
  showHook
>
  <SignatureShowcase />
  <MoreFlavours />
  <Hero />
  <Manifesto />
  <BookingForm />
</Base>
