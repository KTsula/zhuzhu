---
interface Props {
  n: string;
  title: string;
  ka?: string;
  text: string;
}
const { n, title, ka, text } = Astro.props;
---
<div class="step">
  <span class="n">{n}</span>
  <div>
    <b>{title}{ka && <span class="ka"> · {ka}</span>}</b>
    <span class="txt">{text}</span>
  </div>
</div>

<style>
  .step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 22px;
    padding: 22px 0;
    border-top: 1px solid var(--gold-hair);
    align-items: baseline;
  }
  .step:last-child { border-bottom: 1px solid var(--gold-hair); }
  .n {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-gold);
    font-size: 22px;
    letter-spacing: 0.04em;
    font-weight: 500;
  }
  b {
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 24px;
    font-weight: 500;
    color: var(--color-bone);
    margin-bottom: 6px;
  }
  .ka {
    font-family: var(--font-ka);
    font-style: italic;
    color: var(--color-gold-bright);
    font-weight: 500;
    font-size: 18px;
  }
  .txt {
    display: block;
    font-size: 17px;
    color: var(--color-bone-warm);
    line-height: 1.55;
    max-width: 480px;
  }
</style>
