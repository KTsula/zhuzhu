---
import LangSwitch from './LangSwitch.astro';
import Wordmark from './Wordmark.astro';
import { footer } from '../content/copy';
---
<footer class="zz-footer">
  <div class="grid">
    <div class="col col-brand">
      <Wordmark size={28} />
      <p class="tagline">
        <span class="lng-en">{footer.en.brandLine}</span>
        <span class="lng-ka">{footer.ka.brandLine}</span>
      </p>
    </div>

    <div class="col">
      <div class="label">
        <span class="lng-en">{footer.en.contact}</span>
        <span class="lng-ka">{footer.ka.contact}</span>
      </div>
      <a class="line" href={`mailto:${footer.en.mail}`}>{footer.en.mail}</a>
    </div>

    <div class="col">
      <div class="label">
        <span class="lng-en">{footer.en.follow}</span>
        <span class="lng-ka">{footer.ka.follow}</span>
      </div>
      {footer.en.socials.map((s, i) => (
        <a class="line" href={s.href} target="_blank" rel="noopener noreferrer">
          <span class="lng-en">{s.label}</span>
          <span class="lng-ka">{footer.ka.socials[i]?.label || s.label}</span>
        </a>
      ))}
    </div>

    <div class="col">
      <div class="label">
        <span class="lng-en">{footer.en.language}</span>
        <span class="lng-ka">{footer.ka.language}</span>
      </div>
      <LangSwitch />
    </div>
  </div>

  <div class="bottom">
    <span class="rights">
      <span class="lng-en">{footer.en.rights}</span>
      <span class="lng-ka">{footer.ka.rights}</span>
    </span>
  </div>
</footer>

<style>
  .zz-footer {
    background: var(--night);
    padding: 88px 40px 40px;
    color: var(--bone);
    border-top: 1px solid rgba(198,152,89,0.18);
  }
  .grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 56px;
  }
  .col { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
  .col-brand { gap: 20px; }
  .tagline {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-sm);
    color: var(--ash);
    line-height: 1.6;
    max-width: 30ch;
    margin: 0;
  }
  html[data-lang="ka"] .tagline { font-family: var(--ka); font-weight: 400; }

  .label {
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ash);
    margin-bottom: 6px;
  }
  html[data-lang="ka"] .label {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .line {
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--bone-warm);
    transition: color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .line { font-family: var(--ka); font-weight: 400; }
  a.line:hover { color: var(--gold-bright); }

  .bottom {
    max-width: 1200px;
    margin: 64px auto 0;
    padding-top: 32px;
    border-top: 1px solid rgba(198,152,89,0.12);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .rights {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-xs);
    color: var(--ash-dim);
    letter-spacing: 0.02em;
  }
  html[data-lang="ka"] .rights { font-family: var(--ka); font-weight: 400; font-size: var(--t-sm); }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .zz-footer { padding: 60px 22px 32px; }
    .grid { grid-template-columns: 1fr; }
    .bottom { margin-top: 48px; }
  }
</style>
