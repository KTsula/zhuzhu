---
import Base from '~/layouts/Base.astro';
import Hero from '~/components/Hero.astro';
import FlavourTicker from '~/components/FlavourTicker.astro';
import MenuRow from '~/components/MenuRow.astro';
import PackageCard from '~/components/PackageCard.astro';
import ProcessStep from '~/components/ProcessStep.astro';
import BookingForm from '~/components/BookingForm.astro';
import Reveal from '~/components/Reveal.astro';
import { flavours } from '~/content/menu';
import { packages, processSteps } from '~/content/packages';
---
<Base
  active="home"
  title="ZhuZhu · ჟუჟუ — Premium Jelly Cocktails for Exclusive Events"
  description="ZhuZhu · ჟუჟუ — premium jelly cocktail shots for weddings, brand activations and after-hours events. Hand-set in Tbilisi."
>
  <Hero />
  <FlavourTicker />

  {/* ── Manifesto ─────────────────────────────────────────── */}
  <div class="frame">
    <section class="manifesto section" id="manifesto">
      <Reveal class="lede">
        <p class="display">
          A cocktail you don’t sip — <em>you bite.</em>
        </p>
      </Reveal>
      <Reveal class="body" delay={120}>
        <p>
          ZhuZhu is a small Tbilisi atelier setting cocktails into jelly — by the gram,
          the millilitre, the hour. No shortcuts, no novelty. Clean spirits, clean
          juice and a long cold rest.
        </p>
        <p>
          Built around a Georgian signature line: Saperavi sangria, chacha and honey,
          churchkhela cream, tarragon lemonade. Familiar classics for the room that
          wants them, and a full alcohol-free collection that looks the same on the tray.
        </p>
        <p>
          We work with planners, hotels, brand teams and small parties — from a
          fifty-shot tray to a three-hundred-shot dressed jelly bar with a host on site.
        </p>
      </Reveal>
    </section>
  </div>

  {/* ── Menu preview ──────────────────────────────────────── */}
  <div class="frame">
    <section class="section" id="menu" aria-labelledby="menu-h">
      <Reveal>
        <header class="section-head">
          <div>
            <p class="num"><b>— I.</b>&nbsp;&nbsp;The Menu</p>
            <h2 id="menu-h" style="margin-top:18px;">
              Twelve <em>cuts.</em>
              <span class="ge">გემოები ოთხ ხაზად</span>
            </h2>
          </div>
          <div>
            <p class="blurb">
              Four lines: a Georgian signature collection, dessert-grade premium, the
              familiar classics, and a non-alcoholic line that looks as good as the rest.
              The full list lives on the <a href="/menu" class="under">menu page</a>.
            </p>
          </div>
        </header>
      </Reveal>

      <div class="menu-list">
        {flavours.map((f, i) => (
          <Reveal delay={Math.min(i, 6) * 40}>
            <MenuRow flavour={f} index={i + 1} />
          </Reveal>
        ))}
      </div>

      <Reveal>
        <div class="menu-foot">
          <a href="/menu" class="btn-ghost">See the full menu →</a>
        </div>
      </Reveal>
    </section>
  </div>

  {/* ── Packages ──────────────────────────────────────────── */}
  <div class="frame">
    <section class="section" id="packages" aria-labelledby="packages-h">
      <Reveal>
        <header class="section-head">
          <div>
            <p class="num"><b>— II.</b>&nbsp;&nbsp;The Packages</p>
            <h2 id="packages-h" style="margin-top:18px;">
              From a table<br />to a <em>full bar.</em>
              <span class="ge">პაკეტები ნებისმიერი ივენთისთვის</span>
            </h2>
          </div>
          <div>
            <p class="blurb">
              Three ways to bring ZhuZhu into your event. Every package includes labelled
              cups with allergens, menu cards, a chilled transport box and a clear
              handover. Live setup adds one host and a dressed jelly bar on site.
            </p>
          </div>
        </header>
      </Reveal>

      <div class="pkg-grid">
        {packages.map((p, i) => (
          <Reveal delay={i * 80}>
            <PackageCard pkg={p} />
          </Reveal>
        ))}
      </div>
    </section>
  </div>

  {/* ── Process ───────────────────────────────────────────── */}
  <div class="frame">
    <section class="section" id="process" aria-labelledby="process-h">
      <Reveal>
        <header class="section-head">
          <div>
            <p class="num"><b>— III.</b>&nbsp;&nbsp;The Process</p>
            <h2 id="process-h" style="margin-top:18px;">
              A small kitchen,<br />a <em>tight standard.</em>
              <span class="ge">პატარა სამზარეულო, მკაცრი სტანდარტი</span>
            </h2>
          </div>
          <div>
            <p class="blurb">
              HACCP-aligned recipe cards. Excise-stamped spirits, food-grade gelatin,
              every cup labelled with allergens, ABV and an 18+ mark. The cube you taste
              in the sample box is the cube your guests eat at the event.
            </p>
          </div>
        </header>
      </Reveal>

      <div class="steps">
        {processSteps.map((s, i) => (
          <Reveal delay={i * 60}>
            <ProcessStep n={s.n} title={s.title} ka={s.ka} text={s.text} />
          </Reveal>
        ))}
      </div>
    </section>
  </div>

  {/* ── Editorial quote ──────────────────────────────────── */}
  <div class="frame">
    <section class="editorial">
      <Reveal>
        <span class="mark" aria-hidden="true">“</span>
        <blockquote>
          Taste Georgia in<br />
          one <em>jelly shot.</em>
          <span class="ge">გასინჯე საქართველო ერთ ბრჩხინში.</span>
        </blockquote>
        <cite>— ZhuZhu · ჟუჟუ</cite>
      </Reveal>
    </section>
  </div>

  {/* ── Booking + contact ────────────────────────────────── */}
  <div class="frame">
    <section class="section" id="book" aria-labelledby="book-h" style="padding-top:0;">
      <Reveal>
        <div class="reserve-section">
          <div>
            <p class="num"><b>— IV.</b>&nbsp;&nbsp;Reserve</p>
            <h2 id="book-h" style="margin-top:18px;">
              Tell us about<br />your <em>event.</em>
              <span class="ge">დაგვიკავშირდი</span>
            </h2>
            <p class="blurb">
              Send the form, message us on Instagram, or write directly. We reply within
              two working days with a draft menu and a quote.
            </p>
            <div class="reserve-meta">
              <div>
                <b>Email</b>
                <a href="mailto:shezhuzhundi@gmail.com">shezhuzhundi@gmail.com</a>
              </div>
              <div>
                <b>Instagram</b>
                <a href="https://instagram.com/she_zhuzhu_ndi" target="_blank" rel="noopener noreferrer">@she_zhuzhu_ndi</a>
              </div>
              <div>
                <b>TikTok</b>
                <a href="https://tiktok.com/@she_zhuzhu_ndi" target="_blank" rel="noopener noreferrer">@she_zhuzhu_ndi</a>
              </div>
              <div>
                <b>Facebook</b>
                {/* TODO: replace # with the real FB page URL once confirmed */}
                <a href="#" data-todo="confirm FB page URL" target="_blank" rel="noopener noreferrer">ZhuZhu · ჟუჟუ</a>
              </div>
              <div>
                <b>Based in</b>
                <span>Tbilisi · თბილისი</span>
              </div>
            </div>
          </div>
          <BookingForm />
        </div>
      </Reveal>
    </section>
  </div>
</Base>

<style>
  /* ── Manifesto ───────────────────────────────────────── */
  .manifesto {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    padding-top: 140px;
  }
  .manifesto .lede .display {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(40px, 5vw, 80px);
    line-height: 1.02;
    letter-spacing: -0.018em;
    color: var(--color-bone);
  }
  .manifesto .lede em {
    font-style: italic;
    color: var(--color-wine-glow);
  }
  .manifesto .body p {
    font-size: 18px;
    line-height: 1.72;
    color: var(--color-bone-warm);
    max-width: 520px;
  }
  .manifesto .body p + p { margin-top: 18px; }
  @media (max-width: 1100px) {
    .manifesto { grid-template-columns: 1fr; gap: 32px; padding-top: 90px; }
  }

  /* ── Menu list ───────────────────────────────────────── */
  .menu-list {
    border-top: 1px solid var(--gold-hair);
    border-bottom: 1px solid var(--gold-hair);
  }
  .menu-foot {
    margin-top: 36px;
    display: flex;
    justify-content: flex-end;
  }
  .under {
    border-bottom: 1px solid var(--gold-line);
    color: var(--color-gold-bright);
  }

  /* ── Packages grid ──────────────────────────────────── */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  @media (max-width: 1100px) {
    .pkg-grid { grid-template-columns: 1fr; }
  }

  /* ── Process steps wrapper ──────────────────────────── */
  .steps { display: grid; gap: 0; }

  /* ── Editorial quote band ───────────────────────────── */
  .editorial {
    position: relative;
    padding: 160px 0;
    text-align: center;
  }
  .editorial .mark {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-gold);
    font-size: 100px;
    line-height: 0;
    display: block;
    margin-bottom: 50px;
    text-shadow: 0 0 30px rgba(227, 183, 109, 0.25);
  }
  .editorial blockquote {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(36px, 4.6vw, 68px);
    line-height: 1.12;
    letter-spacing: -0.012em;
    max-width: 1100px;
    margin: 0 auto;
    color: var(--color-bone);
  }
  .editorial blockquote em { color: var(--color-wine-glow); }
  .editorial blockquote .ge {
    display: block;
    margin-top: 24px;
    font-family: var(--font-ka);
    font-style: italic;
    color: var(--color-gold-bright);
    font-size: 0.45em;
    font-weight: 500;
  }
  .editorial cite {
    display: block;
    margin-top: 48px;
    font-style: normal;
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.28em;
    color: var(--color-ash-dim);
  }

  /* ── Reserve section ────────────────────────────────── */
  .reserve-section {
    position: relative;
    background:
      radial-gradient(700px 400px at 20% 30%, rgba(138, 31, 60, 0.10), transparent 60%),
      radial-gradient(700px 500px at 80% 70%, rgba(198, 152, 89, 0.10), transparent 60%),
      var(--color-graphite);
    border: 1px solid var(--gold-line);
    padding: 80px 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 60px;
  }
  .reserve-section::before {
    content: "";
    position: absolute;
    inset: 14px;
    pointer-events: none;
    border: 1px solid var(--gold-hair);
  }
  .reserve-section > * { position: relative; z-index: 1; }
  .reserve-section h2 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(44px, 5.2vw, 80px);
    line-height: 0.98;
    letter-spacing: -0.018em;
    color: var(--color-bone);
  }
  .reserve-section h2 em { color: var(--color-wine-glow); }
  .reserve-section h2 .ge {
    display: block;
    font-family: var(--font-ka);
    font-style: italic;
    color: var(--color-gold-bright);
    font-size: 0.5em;
    margin-top: 10px;
  }
  .reserve-section .blurb {
    margin-top: 22px;
    font-size: 17.5px;
    color: var(--color-bone-warm);
    line-height: 1.7;
    max-width: 460px;
  }
  .reserve-meta {
    margin-top: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
  }
  .reserve-meta b {
    display: block;
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.24em;
    color: var(--color-gold);
    margin-bottom: 10px;
  }
  .reserve-meta span {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--color-bone);
  }
  .reserve-meta a {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--color-gold-bright);
    border-bottom: 1px solid var(--gold-line);
    padding-bottom: 2px;
    transition: color 0.25s, border-color 0.25s;
  }
  .reserve-meta a:hover {
    color: var(--color-bone);
    border-color: var(--color-gold-bright);
  }

  @media (max-width: 1100px) {
    .reserve-section { grid-template-columns: 1fr; padding: 48px 28px; }
    .reserve-meta { grid-template-columns: 1fr; }
  }
</style>
