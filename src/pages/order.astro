---
import Base from '../layouts/Base.astro';
import BookingForm from '../components/BookingForm.astro';
import { orderPage, pageMeta, signatures, classics, menuClassics } from '../content/copy';

const rows = [
  ...signatures.map((s) => ({
    name: s.name,
    accent: s.accent,
    img: s.img,
    tag: { en: s.line.en, ka: s.line.ka },
    premium: true,
  })),
  ...classics.map((c) => ({
    name: c.name,
    accent: c.accent,
    img: null,
    tag: { en: menuClassics.en.eyebrow, ka: menuClassics.ka.eyebrow },
    premium: false,
  })),
];
---
<Base current="order"
      title={pageMeta.order.en.title}
      description={pageMeta.order.en.desc}>
  <section class="order-head">
    <h1 class="display title">
      <span class="lng-en">{orderPage.en.head}</span>
      <span class="lng-ka">{orderPage.ka.head}</span>
    </h1>
    <p class="sub">
      <span class="lng-en">{orderPage.en.sub}</span>
      <span class="lng-ka">{orderPage.ka.sub}</span>
    </p>
  </section>

  <section class="order-list">
    {rows.map((r) => (
      <div class:list={["row", r.premium && 'premium']}>
        <div class="thumb">
          <div class="glow" style={`background: radial-gradient(62% 52% at 50% 55%, ${r.accent} 0%, rgba(10,7,6,0) 72%)`}></div>
          {r.img && <img src={r.img} alt={r.name.en} onerror="this.style.display='none'" />}
        </div>
        <div class="meta">
          <span class="tag">
            <span class="lng-en">{r.tag.en}</span>
            <span class="lng-ka">{r.tag.ka}</span>
          </span>
          <span class="name">
            <span class="lng-en">{r.name.en}</span>
            <span class="lng-ka">{r.name.ka}</span>
          </span>
        </div>
      </div>
    ))}
  </section>

  <BookingForm />
</Base>

<style>
  .order-head {
    padding: 120px 24px 72px;
    background: var(--night);
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .order-head .title { font-size: var(--t-display); margin: 0; }
  .order-head .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 48ch;
    margin: 32px auto 0;
  }
  html[data-lang="ka"] .order-head .sub { font-family: var(--ka); font-weight: 400; }

  .order-list {
    max-width: 920px;
    margin: 0 auto 40px;
    padding: 0 40px;
  }
  .row {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 24px 0;
    border-top: 1px solid rgba(198,152,89,0.15);
  }
  .row:last-child { border-bottom: 1px solid rgba(198,152,89,0.15); }

  .thumb {
    position: relative;
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .thumb .glow { position: absolute; inset: 0; }
  .thumb img {
    position: absolute;
    inset: 8px;
    width: calc(100% - 16px);
    height: calc(100% - 16px);
    object-fit: contain;
  }

  .meta { flex: 1; min-width: 0; }
  .tag {
    display: block;
    font-family: var(--body);
    font-weight: 600;
    font-size: var(--t-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 7px;
  }
  .row.premium .tag { color: var(--gold); }
  html[data-lang="ka"] .tag {
    font-family: var(--ka);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-lg);
    color: var(--bone);
  }
  html[data-lang="ka"] .name { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 720px) {
    .order-head { padding: 80px 22px 56px; }
    .order-head .sub { font-size: var(--t-base); }
    .order-list { padding: 0 22px; }
    .row { gap: 18px; padding: 20px 0; }
    .thumb { width: 48px; height: 48px; }
    .name { font-size: var(--t-base); }
  }
</style>
