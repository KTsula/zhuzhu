---
import Base from '../../layouts/Base.astro';
import { journal, pageMeta } from '../../content/copy';

function fmtDate(iso: string, lang: 'en' | 'ka') {
  const d = new Date(iso);
  return d.toLocaleDateString(lang === 'ka' ? 'ka-GE' : 'en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---
<Base current="home"
      title={pageMeta.journal.en.title}
      description={pageMeta.journal.en.desc}>

  <section class="jx">
    <header class="jx-head">
      <span class="label">
        <span class="lng-en">{journal.index.en.eyebrow}</span>
        <span class="lng-ka">{journal.index.ka.eyebrow}</span>
      </span>
      <h1 class="display title">
        <span class="lng-en">{journal.index.en.head}</span>
        <span class="lng-ka">{journal.index.ka.head}</span>
      </h1>
      <p class="sub">
        <span class="lng-en">{journal.index.en.sub}</span>
        <span class="lng-ka">{journal.index.ka.sub}</span>
      </p>
    </header>

    <ul class="post-list">
      {journal.posts.map((p) => (
        <li class="post">
          <a href={`/journal/${p.slug}`}>
            <div class="meta">
              <time datetime={p.date}>
                <span class="lng-en">{fmtDate(p.date, 'en')}</span>
                <span class="lng-ka">{fmtDate(p.date, 'ka')}</span>
              </time>
              <span class="dot">·</span>
              <span class="reading">
                <span class="lng-en">{p.readingMinutes} min read</span>
                <span class="lng-ka">{p.readingMinutes} წთ კითხვა</span>
              </span>
            </div>
            <h2 class="display post-title">
              <span class="lng-en">{p.title.en}</span>
              <span class="lng-ka">{p.title.ka}</span>
            </h2>
            <p class="lede">
              <span class="lng-en">{p.lede.en}</span>
              <span class="lng-ka">{p.lede.ka}</span>
            </p>
            <span class="read-cta">
              <span class="lng-en">Read  →</span>
              <span class="lng-ka">წაიკითხე  →</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .jx { max-width: 820px; margin: 0 auto; padding: 120px 24px 120px; }
  .jx-head { text-align: center; margin-bottom: 80px; }
  .title { font-size: var(--t-3xl); margin: 14px 0 20px; line-height: 1.1; }
  .sub {
    font-family: var(--body); font-weight: 350; font-size: var(--t-lg);
    color: var(--bone-warm); line-height: 1.55; margin: 0 auto; max-width: 40ch;
  }
  html[data-lang="ka"] .sub { font-family: var(--ka); font-weight: 400; }

  .post-list { list-style: none; padding: 0; margin: 0; }
  .post {
    border-top: 1px solid rgba(198,152,89,0.20);
    padding: 36px 0;
  }
  .post:last-child { border-bottom: 1px solid rgba(198,152,89,0.20); }
  .post a { display: block; }
  .post a:hover .post-title { color: var(--gold-bright); }
  .post a:hover .read-cta { color: var(--gold-bright); transform: translateX(2px); }

  .meta {
    font-family: var(--body); font-weight: 500; font-size: var(--t-xs);
    text-transform: uppercase; letter-spacing: 0.16em; color: var(--ash);
    display: flex; align-items: center; gap: 12px;
  }
  html[data-lang="ka"] .meta {
    font-family: var(--ka); font-style: italic; font-weight: 400;
    text-transform: none; letter-spacing: 0.04em; font-size: var(--t-sm);
  }
  .meta .dot { color: var(--gold); }

  .post-title {
    font-size: var(--t-2xl); margin: 14px 0 14px;
    transition: color 0.3s var(--ease-out-quart);
  }
  .lede {
    font-family: var(--display); font-style: italic; font-weight: 300;
    font-size: var(--t-lg); color: var(--bone-warm); line-height: 1.5;
    margin: 0 0 18px; max-width: 56ch;
  }
  html[data-lang="ka"] .lede { font-family: var(--ka); }
  .read-cta {
    font-family: var(--body); font-weight: 600; font-size: var(--t-xs);
    text-transform: uppercase; letter-spacing: 0.16em; color: var(--gold);
    display: inline-block;
    transition: color 0.3s var(--ease-out-quart), transform 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .read-cta {
    font-family: var(--ka); font-style: italic; font-weight: 400;
    text-transform: none; letter-spacing: 0.04em; font-size: var(--t-sm);
  }

  @media (max-width: 720px) {
    .jx { padding: 72px 22px 80px; }
    .jx-head { margin-bottom: 48px; }
    .post-title { font-size: var(--t-xl); }
  }
</style>
