---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal.astro';

// TODO: refine roles + add real bios when finalised
const founders = [
  { initial: 'K', name: 'Keti', role: 'Co-founder' },
  { initial: 'A', name: 'Anna', role: 'Co-founder' },
  { initial: 'L', name: 'Lado', role: 'Co-founder' },
];
---
<Base
  active="about"
  title="About — ZhuZhu · ჟუჟუ"
  description="Three co-founders, a small Tbilisi kitchen, a love for the Georgian table. The ZhuZhu story."
>
  <div class="frame">
    <section class="section">
      <Reveal>
        <header class="section-head" style="margin-bottom:60px;">
          <div>
            <p class="num"><b>— About</b>&nbsp;&nbsp;ZhuZhu · ჟუჟუ</p>
            <h1 style="margin-top:18px;">
              Three people,<br />one <em>small kitchen.</em>
              <span class="ge">სამი დამფუძნებელი, ერთი პატარა სამზარეულო</span>
            </h1>
          </div>
          <div>
            <p class="blurb">
              ZhuZhu was started in Tbilisi in 2026 by three friends who kept ending up in
              the same kitchen at the end of every dinner — pouring the last of the wine
              into whatever else was on the table. One of those wines became the first
              Saperavi cube.
            </p>
            <p class="blurb" style="margin-top:14px;">
              We’re soft-starting this year, ahead of formal registration. Small batches,
              real cards, every shot labelled — the way it’ll keep being made.
            </p>
          </div>
        </header>
      </Reveal>

      <Reveal>
        <div class="founders">
          {founders.map((f) => (
            <article class="founder">
              <div class="portrait" aria-hidden="true">{f.initial}</div>
              <h3>{f.name}</h3>
              <p class="role">{f.role}</p>
              <p class="bio">
                {/* TODO: bio placeholder — fill once finalised */}
                Short bio coming soon — a sentence on who they are, what they do at ZhuZhu,
                and where to find them on a Friday night.
              </p>
            </article>
          ))}
        </div>
      </Reveal>

      <Reveal>
        <section class="tbilisi">
          <div>
            <p class="num">Where we cook</p>
            <h2>Tbilisi · თბილისი</h2>
            <p>
              A small atelier kitchen, food-safe, cold chain unbroken from the fridge to
              your tray. We deliver across the city by appointment, and travel for
              weddings and brand events on request.
            </p>
          </div>
        </section>
      </Reveal>
    </section>
  </div>
</Base>

<style>
  h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(52px, 6.4vw, 100px);
    line-height: 0.94;
    letter-spacing: -0.018em;
    color: var(--color-bone);
  }
  h1 em { color: var(--color-wine-glow); }
  h1 .ge {
    display: block;
    font-family: var(--font-ka);
    font-style: italic;
    color: var(--color-gold-bright);
    font-size: 0.5em;
    margin-top: 12px;
  }

  .founders {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-bottom: 100px;
  }
  @media (max-width: 1100px) { .founders { grid-template-columns: 1fr; } }
  .founder {
    border: 1px solid var(--gold-hair);
    padding: 32px;
    background: rgba(20, 16, 13, 0.5);
  }
  .portrait {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--color-gold);
    color: var(--color-night);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 44px;
    margin-bottom: 22px;
  }
  .founder h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 28px;
    color: var(--color-bone);
    letter-spacing: -0.005em;
  }
  .founder .role {
    margin-top: 4px;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-gold-bright);
    font-size: 16px;
  }
  .founder .bio {
    margin-top: 14px;
    color: var(--color-bone-warm);
    font-size: 16px;
    line-height: 1.7;
  }

  .tbilisi {
    border-top: 1px solid var(--gold-hair);
    padding-top: 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
  @media (max-width: 1100px) { .tbilisi { grid-template-columns: 1fr; } }
  .tbilisi .num {
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-gold);
    font-size: 12.5px;
    letter-spacing: 0.26em;
  }
  .tbilisi h2 {
    margin-top: 12px;
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(44px, 5.2vw, 76px);
    letter-spacing: -0.018em;
    color: var(--color-bone);
  }
  .tbilisi p {
    margin-top: 22px;
    color: var(--color-bone-warm);
    font-size: 17.5px;
    line-height: 1.7;
    max-width: 520px;
  }
</style>
