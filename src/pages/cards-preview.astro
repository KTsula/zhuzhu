---
// Preview page for the business cards. Not linked from nav/sitemap —
// just a local viewing surface during design iteration. Safe to delete
// when the cards are finalised and at the printer.

const cards = [
  { key: 'front',        label: 'Front · same on every card' },
  { key: 'back-generic', label: 'Back · generic (brand)' },
  { key: 'back-keti',    label: 'Back · Keti / Co-founder' },
  { key: 'back-anna',    label: 'Back · Anna / Co-founder' },
  { key: 'back-lado',    label: 'Back · Lado / Co-founder' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZhuZhu — Business card preview</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600&family=Spectral:ital,wght@0,300;1,300;1,400&family=Noto+Serif+Georgian:wght@400&display=swap" />
    <style>
      :root {
        --night: #0a0706;
        --graphite: #14100d;
        --bone: #ede1c4;
        --bone-warm: #e3d3ab;
        --ash: #b3a48a;
        --gold: #c69859;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--graphite);
        color: var(--bone);
        font-family: Manrope, sans-serif;
        min-height: 100vh;
      }
      .page {
        max-width: 920px;
        margin: 0 auto;
        padding: 56px 24px 80px;
      }
      header {
        text-align: center;
        margin-bottom: 56px;
      }
      h1 {
        font-family: Spectral, Georgia, serif;
        font-style: italic;
        font-weight: 300;
        font-size: clamp(28px, 4vw, 40px);
        margin: 0;
        letter-spacing: -0.01em;
      }
      .meta {
        margin-top: 16px;
        color: var(--ash);
        font-size: 14px;
        letter-spacing: 0.04em;
      }
      .cards {
        display: flex;
        flex-direction: column;
        gap: 40px;
      }
      .card-wrap {
        display: flex;
        flex-direction: column;
        gap: 14px;
        align-items: center;
      }
      .card {
        width: 100%;
        max-width: 720px;
        aspect-ratio: 85 / 55;
        box-shadow:
          0 20px 60px rgba(0, 0, 0, 0.5),
          0 4px 12px rgba(0, 0, 0, 0.6),
          0 0 0 1px rgba(198, 152, 89, 0.08);
        display: block;
        object-fit: contain;
        background: var(--night);
      }
      .label {
        font-family: Manrope, sans-serif;
        font-weight: 500;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
      }
      .scale-note {
        text-align: center;
        margin-top: 40px;
        color: var(--ash);
        font-size: 13px;
        line-height: 1.6;
        max-width: 56ch;
        margin-left: auto;
        margin-right: auto;
      }
      .scale-note em {
        font-family: Spectral, Georgia, serif;
        font-weight: 300;
      }
      @media (max-width: 720px) {
        .page { padding: 36px 16px 60px; }
        .cards { gap: 32px; }
        header { margin-bottom: 36px; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header>
        <h1>Business cards</h1>
        <p class="meta">85 × 55 mm · European standard · 3 mm bleed</p>
      </header>

      <div class="cards">
        {cards.map((c) => (
          <figure class="card-wrap" style="margin:0">
            <img class="card" src={`/cards/${c.key}.png`} alt={c.label} />
            <figcaption class="label">{c.label}</figcaption>
          </figure>
        ))}
      </div>

      <p class="scale-note">
        These previews are rendered at approximately <em>2×</em> print size.
        The actual cards print at 85 × 55 mm — for a true-to-life preview,
        view this page on a desktop and resize the browser window so each
        card is about the width of two credit cards.
      </p>
    </div>
  </body>
</html>
