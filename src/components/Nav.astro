---
interface Props {
  active?: 'home' | 'menu' | 'packages' | 'process' | 'book' | 'about';
}
const { active } = Astro.props;

const links: { href: string; label: string; key: NonNullable<Props['active']> }[] = [
  { href: '/menu',     label: 'Menu',     key: 'menu' },
  { href: '/packages', label: 'Packages', key: 'packages' },
  { href: '/#process', label: 'Process',  key: 'process' },
  { href: '/about',    label: 'About',    key: 'about' },
];
---
<div class="frame">
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="ZhuZhu home">
      <picture>
        <source srcset="/logo.webp" type="image/webp" />
        <img src="/logo.png" alt="ZhuZhu · ჟუჟუ" width="800" height="800" />
      </picture>
    </a>
    <ul>
      {links.map((l) => (
        <li>
          <a href={l.href} class={active === l.key ? 'is-active' : ''}>{l.label}</a>
        </li>
      ))}
    </ul>
    <div class="right">
      <a href="/book" class="reserve" data-active={active === 'book' ? 'true' : 'false'}>
        Reserve a date
      </a>
    </div>
  </nav>
</div>

<style>
  .site-nav {
    position: relative;
    z-index: 5;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 30px 0 24px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    line-height: 0;
  }
  .brand img {
    height: 64px;
    width: auto;
    display: block;
  }
  @media (max-width: 1100px) {
    .brand img { height: 52px; }
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 30px;
    justify-self: center;
    margin: 0;
    padding: 0;
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    color: var(--color-bone-warm);
  }
  .site-nav ul a {
    opacity: 0.72;
    transition: opacity 0.25s, color 0.25s;
  }
  .site-nav ul a:hover,
  .site-nav ul a.is-active { opacity: 1; color: var(--color-gold-bright); }

  .right { justify-self: end; display: flex; align-items: center; gap: 22px; }

  .reserve {
    font-family: var(--font-serif);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.22em;
    border: 1px solid var(--gold-line);
    color: var(--color-gold-bright);
    padding: 9px 18px;
    border-radius: 999px;
    transition: all 0.35s ease;
  }
  .reserve:hover,
  .reserve[data-active="true"] {
    background: var(--color-gold);
    color: var(--color-night);
    border-color: var(--color-gold);
  }

  @media (max-width: 1100px) {
    .site-nav { grid-template-columns: auto auto; }
    .site-nav ul { display: none; }
  }
</style>
