---
import Base from '../layouts/Base.astro';
import { menuPage, pageMeta, sharedLabels, signatures } from '../content/copy';
---
<Base current="menu"
      title={pageMeta.menu.en.title}
      description={pageMeta.menu.en.desc}>
  <section class="menu-head">
    <h1 class="display title">
      <span class="lng-en">{menuPage.en.head}</span>
      <span class="lng-ka">{menuPage.ka.head}</span>
    </h1>
    <p class="sub">
      <span class="lng-en">{menuPage.en.sub}</span>
      <span class="lng-ka">{menuPage.ka.sub}</span>
    </p>
  </section>

  {signatures.map((s, i) => (
    <article class:list={["spread", i % 2 === 1 && 'right']}>
      <div class="text-side">
        <div class="line-row">
          <span class="line-no">{s.id}</span>
          <span class="line-name lng-en">{s.line.en}</span>
          <span class="line-name lng-ka">{s.line.ka}</span>
        </div>
        <h2 class="display name">
          <span class="lng-en">{s.name.en}</span>
          <span class="lng-ka ka">{s.name.ka}</span>
        </h2>
        <p class="blurb">
          <span class="lng-en">{s.blurb.en}</span>
          <span class="lng-ka">{s.blurb.ka}</span>
        </p>
        <div class="meta">
          <div class="m">
            <div class="label">
              <span class="lng-en">{sharedLabels.en.line}</span>
              <span class="lng-ka">{sharedLabels.ka.line}</span>
            </div>
            <div class="v">
              <span class="lng-en">{s.meta.line.en}</span>
              <span class="lng-ka">{s.meta.line.ka}</span>
            </div>
          </div>
          <div class="m">
            <div class="label">
              <span class="lng-en">{sharedLabels.en.price}</span>
              <span class="lng-ka">{sharedLabels.ka.price}</span>
            </div>
            <div class="v">
              <span class="lng-en">₾{s.price * 8} {sharedLabels.en.perSet}</span>
              <span class="lng-ka">₾{s.price * 8} {sharedLabels.ka.perSet}</span>
            </div>
          </div>
        </div>
      </div>
      <div class="image-side">
        <div class="glow" style={`background: radial-gradient(60% 50% at 50% 55%, ${s.accent} 0%, rgba(10,7,6,0) 70%)`}></div>
        <img src={s.img} alt={s.name.en} onerror="this.style.display='none'" />
        <div class="corner"><span class="no">№ {s.id}</span></div>
      </div>
    </article>
  ))}

  <section class="closer">
    <h2 class="display closer-text">
      <span class="lng-en">{menuPage.en.closerHead}</span>
      <span class="lng-ka">{menuPage.ka.closerHead}</span>
    </h2>
    <p class="closer-sub">
      <span class="lng-en">{menuPage.en.closerSub}</span>
      <span class="lng-ka">{menuPage.ka.closerSub}</span>
    </p>
    <a class="cta" href="/order">
      <span class="lng-en">{menuPage.en.closerCta}</span>
      <span class="lng-ka">{menuPage.ka.closerCta}</span>
    </a>
  </section>
</Base>

<style>
  .menu-head {
    padding: 120px 24px 80px;
    background: var(--night);
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .menu-head .title {
    font-size: var(--t-display);
    margin: 0;
  }
  .menu-head .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 46ch;
    margin: 32px auto 0;
  }
  html[data-lang="ka"] .menu-head .sub { font-family: var(--ka); font-weight: 400; }

  .spread {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 640px;
    background: var(--night);
  }
  .spread.right .text-side  { order: 2; }
  .spread.right .image-side { order: 1; }

  .text-side {
    padding: 96px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .line-row { display: flex; align-items: baseline; gap: 16px; margin-bottom: 40px; }
  .line-no {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-lg);
    color: var(--gold);
  }
  .line-name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
  }
  html[data-lang="ka"] .line-name {
    font-family: var(--ka);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: var(--t-sm);
  }
  .name {
    margin: 0;
    font-size: var(--t-3xl);
  }
  .name .ka { font-size: clamp(2rem, 4vw, 3rem); }
  .blurb {
    margin: 32px 0 0;
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-base);
    line-height: 1.65;
    color: var(--bone-warm);
    max-width: 48ch;
  }
  html[data-lang="ka"] .blurb { font-family: var(--ka); font-weight: 400; }
  .meta {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(2, auto);
    gap: 28px 64px;
  }
  .meta .v {
    margin-top: 8px;
    font-family: var(--body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--bone);
  }
  html[data-lang="ka"] .meta .v { font-family: var(--ka); }

  .image-side {
    position: relative;
    overflow: hidden;
    background: var(--night);
    min-height: 480px;
  }
  .image-side .glow { position: absolute; inset: 0; }
  .image-side img {
    position: absolute;
    inset: 180px;
    width: calc(100% - 360px);
    height: calc(100% - 360px);
    object-fit: contain;
    z-index: 2;
  }
  .image-side .corner {
    position: absolute;
    top: 32px;
    right: 36px;
    z-index: 4;
  }
  .image-side .no {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-base);
    color: var(--bone-warm);
    opacity: 0.5;
  }

  .closer {
    text-align: center;
    padding: 140px 24px;
    background: var(--night);
    max-width: 720px;
    margin: 0 auto;
  }
  .closer-text {
    font-size: var(--t-3xl);
    margin: 0;
  }
  .closer-sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 44ch;
    margin: 32px auto 44px;
  }
  html[data-lang="ka"] .closer-sub { font-family: var(--ka); font-weight: 400; }

  @media (max-width: 1024px) {
    .spread { grid-template-columns: 1fr; }
    .spread .text-side { order: 2; }
    .spread .image-side { order: 1; }
  }
  @media (max-width: 720px) {
    .menu-head { padding: 80px 22px 60px; }
    .menu-head .sub { font-size: var(--t-base); }
    .text-side { padding: 56px 24px; }
    .meta { grid-template-columns: 1fr 1fr; gap: 24px 32px; margin-top: 40px; }
    .image-side { min-height: 360px; }
    .image-side img { inset: 100px; width: calc(100% - 200px); height: calc(100% - 200px); }
    .closer { padding: 80px 22px; }
    .closer-sub { font-size: var(--t-base); margin: 24px auto 32px; }
  }
</style>
