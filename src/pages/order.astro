---
import Base from '../layouts/Base.astro';
import Packages from '../components/Packages.astro';
import BookingForm from '../components/BookingForm.astro';
import { signatures } from '../content/copy';
---
<Base current="order"
      title="Order. ZhuZhu, cocktail desserts."
      description="Order ZhuZhu cocktail desserts for your event. Per-cube pricing, minimum ₾250. Tbilisi delivery.">
  <section class="order-head">
    <h1 class="display title">
      <span class="lng-en">Three cubes. Your numbers.</span>
      <span class="lng-ka">სამი კუბი. შენი რაოდენობა.</span>
    </h1>
    <p class="sub">
      <span class="lng-en">Per-cube pricing. Minimum order ₾250. Set the day before, delivered chilled within Tbilisi.</span>
      <span class="lng-ka">კუბზე ფასდება. მინიმუმი ₾250. წინა დღეს ვაყენებთ, თბილისში გაგრილებულად ვაწვდით.</span>
    </p>
  </section>

  <section class="price-strip">
    {signatures.map((s) => (
      <div class="price-row">
        <div class="thumb">
          <div class="glow" style={`background: radial-gradient(60% 50% at 50% 55%, ${s.accent} 0%, rgba(10,7,6,0) 72%)`}></div>
          <img src={s.img} alt={s.name.en} onerror="this.style.display='none'" />
        </div>
        <div class="meta">
          <div class="name">
            <span class="lng-en">{s.name.en}</span>
            <span class="lng-ka">{s.name.ka}</span>
          </div>
          <div class="price">₾{s.price} <span class="per">/ cube</span></div>
        </div>
      </div>
    ))}
  </section>

  <Packages />
  <BookingForm />
</Base>

<style>
  .order-head {
    padding: 120px 24px 80px;
    background: var(--night);
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .order-head .title {
    font-size: var(--t-display);
    margin: 0;
  }
  .order-head .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 48ch;
    margin: 32px auto 0;
  }
  html[data-lang="ka"] .order-head .sub { font-family: var(--ka); font-weight: 400; }

  .price-strip {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid rgba(198,152,89,0.15);
    border-bottom: 1px solid rgba(198,152,89,0.15);
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 32px 24px;
    border-right: 1px solid rgba(198,152,89,0.12);
  }
  .price-row:last-child { border-right: 0; }
  .thumb {
    position: relative;
    width: 76px;
    height: 76px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .thumb .glow { position: absolute; inset: 0; }
  .thumb img {
    position: absolute;
    inset: 10px;
    width: calc(100% - 20px);
    height: calc(100% - 20px);
    object-fit: contain;
  }
  .meta .name {
    font-family: var(--body);
    font-weight: 500;
    font-size: var(--t-base);
    color: var(--bone);
  }
  html[data-lang="ka"] .meta .name { font-family: var(--ka); font-weight: 400; }
  .meta .price {
    font-family: var(--display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--t-xl);
    color: var(--gold-bright);
    margin-top: 4px;
    line-height: 1;
  }
  .meta .per {
    font-family: var(--body);
    font-style: normal;
    font-size: var(--t-sm);
    color: var(--ash);
  }
  html[data-lang="ka"] .meta .per { font-family: var(--ka); }

  @media (max-width: 1024px) {
    .price-strip { grid-template-columns: 1fr; padding: 0; }
    .price-row { border-right: 0; border-bottom: 1px solid rgba(198,152,89,0.12); }
    .price-row:last-child { border-bottom: 0; }
  }
  @media (max-width: 720px) {
    .order-head { padding: 80px 22px 60px; }
    .order-head .sub { font-size: var(--t-base); }
  }
</style>
