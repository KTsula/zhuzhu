---
import { hero } from '../content/copy';
---
<section class="zz-hero">
  <h1 class="slogan display">
    <span class="lng-en">{hero.en.slogan}</span>
    <span class="lng-ka">{hero.ka.slogan}</span>
  </h1>

  <p class="sub">
    <span class="lng-en">{hero.en.sub}</span>
    <span class="lng-ka">{hero.ka.sub}</span>
  </p>

  <div class="cta-wrap">
    <a class="cta" href="/#book">
      <span class="lng-en">{hero.en.cta}</span>
      <span class="lng-ka">{hero.ka.cta}</span>
    </a>
  </div>
</section>

<style>
  .zz-hero {
    background: var(--night);
    text-align: center;
    padding: 140px 24px 120px;
    max-width: 880px;
    margin: 0 auto;
  }
  .slogan {
    font-size: var(--t-display);
    margin: 0;
  }
  .sub {
    font-family: var(--body);
    font-weight: 350;
    font-size: var(--t-lg);
    color: var(--bone-warm);
    line-height: 1.55;
    max-width: 38ch;
    margin: 36px auto 0;
  }
  html[data-lang="ka"] .sub { font-family: var(--ka); font-weight: 400; }

  .cta-wrap {
    margin-top: 56px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 720px) {
    .zz-hero { padding: 96px 22px 88px; }
    .sub { font-size: var(--t-base); margin-top: 28px; }
    .cta-wrap { margin-top: 44px; }
  }
</style>
