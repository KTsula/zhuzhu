---
import { moreFlavours } from '../content/copy';
---
<section class="zz-more">
  <div class="inner">
    <span class="eyebrow label">
      <span class="lng-en">{moreFlavours.en.eyebrow}</span>
      <span class="lng-ka">{moreFlavours.ka.eyebrow}</span>
    </span>
    <a class="peek-link" href="/menu">
      <span class="lng-en">{moreFlavours.en.cta}</span>
      <span class="lng-ka">{moreFlavours.ka.cta}</span>
    </a>
  </div>
</section>

<style>
  .zz-more {
    background: var(--night);
    border-top: 1px solid rgba(198,152,89,0.15);
    border-bottom: 1px solid rgba(198,152,89,0.15);
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .eyebrow { color: var(--ash); }
  .peek-link {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-lg);
    color: var(--bone);
    border-bottom: 1px solid var(--gold);
    padding: 4px 0 6px;
    transition: color 0.3s var(--ease-out-quart), border-color 0.3s var(--ease-out-quart);
  }
  html[data-lang="ka"] .peek-link { font-family: var(--ka); font-weight: 400; }
  .peek-link:hover { color: var(--gold-bright); border-color: var(--gold-bright); }

  @media (max-width: 720px) {
    .inner {
      padding: 24px 22px;
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
    .peek-link {
      font-size: var(--t-base);
      padding: 12px 0;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>
